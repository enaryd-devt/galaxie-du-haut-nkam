<odoo>

    <record id="account_move_print_button_inherit" model="ir.ui.view">
        <field name="name">account.move.print.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">

                <button name="%(primetech_invoice_print_template_selector.action_print_invoice_wizard)d"
                        type="action"
                        string="Modèles d'impression"
                        class="btn-primary"
                        icon="fa-print"/>

            </xpath>

        </field>
    </record>

</odoo>