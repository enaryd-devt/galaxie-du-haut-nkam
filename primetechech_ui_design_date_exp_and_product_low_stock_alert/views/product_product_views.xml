<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================= -->
    <!-- FICHE ARTICLE -->
    <!-- ================================================= -->

    <record
        id="view_product_form_low_stock"
        model="ir.ui.view">

        <field name="name">product.template.low.stock.alert</field>

        <field name="model">product.template</field>

        <field
            name="inherit_id"
            ref="product.product_template_only_form_view"
        />

        <field name="arch" type="xml">

            <xpath
                expr="//field[@name='categ_id']"
                position="after">

                 <field name="discount_percent"/>

                <field name="alert_quantity"/>

                <field name="optimal_quantity"/>

            </xpath>

        </field>

    </record>

</odoo>