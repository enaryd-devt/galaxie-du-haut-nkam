<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_journal_form_security"
            model="ir.ui.view">

        <field name="name">account.journal.form.security</field>

        <field name="model">account.journal</field>

        <field name="inherit_id"
               ref="account.view_account_journal_form"/>

        <field name="arch"
               type="xml">

            <xpath expr="//sheet"
                   position="inside">

                <group string="Sécurité">

                    <field name="allowed_user_ids"
                           widget="many2many_tags"/>

                </group>

            </xpath>

        </field>

    </record>

</odoo>