<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rule_account_journal_visibility"
            model="ir.rule">

        <field name="name">Journal visibility by user</field>

        <field name="model_id"
               ref="account.model_account_journal"/>

        <field name="global"
               eval="True"/>

        <field name="domain_force">

            [
                '|',
                ('allowed_user_ids', '=', False),
                ('allowed_user_ids', 'in', [user.id])
            ]

        </field>

    </record>

</odoo>