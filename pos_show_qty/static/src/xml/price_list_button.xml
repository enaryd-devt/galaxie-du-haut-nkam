<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_realtime_sync.Navbar"
       t-inherit="point_of_sale.Navbar"
       t-inherit-mode="extension">

        <!-- 🔥 1. Ajouter bouton Refresh dans zone navigation -->
        <xpath expr="//div[contains(@class,'navbar-menu')]" position="inside">

            <button class="btn btn-lg lh-lg btn-light refresh-pos"
                    t-on-click="triggerRefresh"
                    title="Refresh POS">

                <i class="fa fa-refresh"/>
                <span t-if="!ui.isSmall">Refresh</span>

            </button>

        </xpath>

        <!-- 🔥 2. Ajouter après CashierName (zone droite) -->
        <xpath expr="//CashierName" position="after">

            <button class="btn btn-light btn-lg lh-lg refresh-pos-right"
                    t-on-click="triggerRefresh"
                    title="Refresh POS">

                <i class="fa fa-refresh"/>
            </button>

        </xpath>

    </t>

</templates>