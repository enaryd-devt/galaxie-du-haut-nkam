<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- ===================================== -->
    <!-- AGENT -->
    <!-- ===================================== -->

    <record
        id="group_stock_replenishment_user"
        model="res.groups"
    >

        <field name="name">
            Agent
        </field>

        <field
            name="category_id"
            ref="primetech_stock_replenishment.module_category_stock_replenishment"
        />

    </record>

    <!-- ===================================== -->
    <!-- RESPONSABLE -->
    <!-- ===================================== -->

    <record
        id="group_stock_replenishment_manager"
        model="res.groups"
    >

        <field name="name">
            Responsable
        </field>

        <field
            name="category_id"
            ref="primetech_stock_replenishment.module_category_stock_replenishment"
        />

        <field
            name="implied_ids"
            eval="[
                (4, ref('primetech_stock_replenishment.group_stock_replenishment_user'))
            ]"
        />

    </record>

</odoo>