<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <!-- ===================================================== -->
    <!-- LIST VIEW -->
    <!-- ===================================================== -->

    <record
        id="view_stock_replenishment_tree"
        model="ir.ui.view"
    >

        <field name="name">pt.stock.replenishment.tree</field>

        <field name="model">pt.stock.replenishment</field>

        <field name="arch" type="xml">

            <list
                decoration-success="state == 'done'"
                decoration-info="state == 'rfq'"
                decoration-warning="state == 'approved'"
                decoration-muted="state == 'cancel'"
            >

                <field name="name"/>

                <field name="date"/>

                <field name="user_id"/>

                <field name="article_count"/>

                <field name="total_qty"/>

                <field
                    name="rfq_count"
                />

                <field
                    name="state"
                    widget="badge"
                />

            </list>

        </field>

    </record>

    <!-- ===================================================== -->
    <!-- FORM VIEW -->
    <!-- ===================================================== -->

    <record
        id="view_stock_replenishment_form"
        model="ir.ui.view"
    >

        <field name="name">pt.stock.replenishment.form</field>

        <field name="model">pt.stock.replenishment</field>

        <field name="arch" type="xml">

            <form>

                <!-- ========================================= -->

                <header>

                    <button
                        name="action_generate_products"
                        type="object"
                        string="Générer les Produits"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />

                    <button
                        name="action_approve"
                        type="object"
                        string="Valider"
                        class="btn-success"
                        invisible="state != 'draft'"
                    />

                    <button
                        name="action_create_rfq"
                        type="object"
                        string="Créer les Demandes de Prix"
                        class="btn-primary"
                        invisible="state != 'approved'"
                    />

                    <button
                        name="action_reset_draft"
                        type="object"
                        string="Remettre en Brouillon"
                        invisible="state == 'draft'"
                    />

                    <button
                        name="action_cancel"
                        type="object"
                        string="Annuler"
                        class="btn-danger"
                        invisible="state in ('cancel','done')"
                    />
                    
                    <button
                        name="%(action_stock_replenishment_report)d"
                        type="action"
                        string="Imprimer"
                        class="btn-secondary"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                    />

                </header>

                <!-- ========================================= -->

                <sheet>

                    <!-- SMART BUTTONS -->

                    <div
                        class="oe_button_box"
                        name="button_box"
                    >

                        <button
                            name="action_view_rfqs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart"
                        >

                            <field
                                name="rfq_count"
                                widget="statinfo"
                                string="Demandes de Prix"
                            />

                        </button>

                    </div>

                    <!-- TITRE -->

                    <div class="oe_title">

                        <h1>

                            <field
                                name="name"
                                readonly="1"
                            />

                        </h1>

                    </div>

                    <!-- INFORMATIONS -->

                    <group>

                        <group>

                            <field name="date"/>

                            <field name="user_id"/>

                        </group>

                        <group>

                            <field name="company_id"/>

                        </group>

                    </group>

                    <!-- KPI -->

                    <group string="Statistiques">

                        <group>

                            <field
                                name="article_count"
                                readonly="1"
                            />

                        </group>

                        <group>

                            <field
                                name="total_qty"
                                readonly="1"
                            />

                        </group>

                    </group>

                    <!-- ONGLETS -->

                    <notebook>

                        <!-- ARTICLES -->

                        <page string="Articles">

                            <field
                                name="line_ids"
                                nolabel="1"
                            >

                                <list
                                    editable="bottom"
                                    default_order="categ_id,product_id"
                                >

                                    <field
                                        name="selected"
                                    />

                                    <field
                                        name="categ_id"
                                        optional="show"
                                    />

                                    <field
                                        name="supplier_id"
                                        optional="show"
                                    />

                                    <field
                                        name="product_id"
                                    />

                                    <field
                                        name="qty_available"
                                        readonly="1"
                                    />

                                    <field
                                        name="alert_quantity"
                                        readonly="1"
                                    />

                                    <field
                                        name="optimal_quantity"
                                        readonly="1"
                                    />

                                    <field
                                        name="qty_to_order"
                                    />

                                    <field
                                        name="urgency"
                                        widget="badge"
                                    />

                                </list>

                            </field>

                        </page>

                        <!-- OBSERVATIONS -->

                        <page string="Observations">

                            <field
                                name="notes"
                                nolabel="1"
                            />

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>

    </record>

</odoo>