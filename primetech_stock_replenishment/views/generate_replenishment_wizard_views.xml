<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record
        id="view_generate_replenishment_wizard"
        model="ir.ui.view"
    >

        <field name="name">pt.generate.replenishment.wizard.form</field>

        <field name="model">pt.generate.replenishment.wizard</field>

        <field name="arch" type="xml">

            <form
                string="Générer un Réapprovisionnement"
            >

                <group>

                    <field
                        name="category_ids"
                        widget="many2many_tags"
                    />

                    <field
                        name="only_with_supplier"
                    />

                </group>

                <footer>

                    <button
                        name="action_generate"
                        type="object"
                        string="Générer"
                        class="btn-primary"
                    />

                    <button
                        string="Annuler"
                        special="cancel"
                    />

                </footer>

            </form>

        </field>

    </record>

    <record
        id="action_generate_replenishment"
        model="ir.actions.act_window"
    >

        <field name="name">Générer un Réapprovisionnement</field>

        <field name="res_model">pt.generate.replenishment.wizard</field>

        <field name="view_mode">form</field>

        <field name="target">new</field>

    </record>

</odoo>