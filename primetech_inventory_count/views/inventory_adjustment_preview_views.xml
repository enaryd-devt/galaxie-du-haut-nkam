<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_inventory_adjustment_preview_tree"
            model="ir.ui.view">

        <field name="name">inventory.adjustment.preview.tree</field>

        <field name="model">primetech.inventory.adjustment.preview</field>

        <field name="arch" type="xml">

            <list
                create="0"
                edit="0"
                delete="0"
                default_order="difference desc">

                <header>

                    <button
                        name="action_export_from_preview"
                        type="object"
                        string="Envoyer vers Odoo"
                        class="btn-primary"
                        icon="fa-upload"/>

                </header>

                <field
                    name="product_id"
                    string="Produit"/>

                <field
                    name="lot_id"
                    optional="show"/>

                <field
                    name="system_location_id"
                    string="Emplacement système"/>

                <field
                    name="count_location_id"
                    string="Emplacement compté"/>

                <field
                    name="qty_system"
                    string="Qté système"/>

                <field
                    name="qty_counted"
                    string="Qté comptée"/>

                <field
                    name="difference"
                    string="Écart"/>

                <field
                    name="difference_type"
                    widget="badge"/>

                <field
                    name="location_difference"
                    string="Écart emplacement"/>

            </list>

        </field>

    </record>

</odoo>