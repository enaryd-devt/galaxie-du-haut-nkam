<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record
        id="view_inventory_apply_wizard_form"
        model="ir.ui.view">

        <field name="name">inventory.apply.wizard.form</field>

        <field name="model">primetech.inventory.apply.wizard</field>

        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field
                            name="sheet_id"
                            readonly="1"/>

                    </group>

                    <field
                        name="line_ids">

                        <list
                            create="0"
                            delete="0">

                            <field name="product_id"/>

                            <field name="lot_id"/>

                            <field name="qty_system"/>

                            <field name="qty_counted"/>

                            <field name="difference"/>

                        </list>

                    </field>

                </sheet>

                <footer>

                    <button
                        string="Appliquer"
                        name="action_apply"
                        type="object"
                        class="btn-primary"/>

                    <button
                        string="Fermer"
                        special="cancel"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>