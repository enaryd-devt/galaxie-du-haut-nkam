<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_inventory_adjustment_log_tree"
            model="ir.ui.view">

        <field name="name">inventory.adjustment.log.tree</field>

        <field name="model">primetech.inventory.adjustment.log</field>

        <field name="arch" type="xml">

            <list create="0"
                  edit="0"
                  delete="0">

                <field name="adjustment_date"/>

                <field name="product_id"/>

                <field name="lot_id"/>

                <field name="warehouse_id"/>

                <field name="location_id"/>

                <field name="qty_system"/>

                <field name="qty_counted"/>

                <field name="difference"/>

                <field name="difference_type"/>

                <field name="counted_by"/>

            </list>

        </field>

    </record>

</odoo>