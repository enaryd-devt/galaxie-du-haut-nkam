<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- LISTE -->
    <!-- ===================================================== -->

    <record id="view_inventory_count_sheet_tree" model="ir.ui.view">
        <field name="name">inventory.count.sheet.tree</field>
        <field name="model">primetech.inventory.count.sheet</field>
        <field name="arch" type="xml">

            <list string="Feuilles de comptage">

                <field name="name"/>
                <field name="date_count"/>
                <field name="warehouse_id"/>
                <field
                    name="location_id"
                    domain="[('id','in',allowed_location_ids)]"
                    readonly="not warehouse_id"
                />

                <field name="user_id"/>

                <field
                    name="state"
                    widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state in ('progress','review')"
                    decoration-success="state in ('validated','exported')"
                    decoration-danger="state == 'cancel'"
                />

            </list>

        </field>
    </record>

    <!-- ===================================================== -->
    <!-- FORMULAIRE -->
    <!-- ===================================================== -->

    <record id="view_inventory_count_sheet_form" model="ir.ui.view">
        <field name="name">inventory.count.sheet.form</field>
        <field name="model">primetech.inventory.count.sheet</field>
        <field name="arch" type="xml">

            <form string="Feuille de comptage">

                <header>

                    <button
                        name="action_generate_lines"
                        type="object"
                        string="Précharger le stock"
                        icon="fa-download"
                        class="btn-secondary"
                        invisible="state != 'draft'"
                    />

                    <button
                        name="action_review"
                        type="object"
                        string="Passer au contrôle"
                        icon="fa-search"
                        class="btn-primary"
                        invisible="state != 'counting'"
                    />

                    <button
                        name="action_preview_adjustments"
                        type="object"
                        string="Prévisualiser"
                        icon="fa-eye"
                        class="btn-info"
                        invisible="state not in ('review','validated')"
                    />

                    <button
                        name="action_validate"
                        type="object"
                        string="Valider le comptage"
                        icon="fa-check-circle"
                        class="btn-success"
                        invisible="state != 'review'"
                    />

                    <button
                        name="action_export_to_odoo_inventory"
                        type="object"
                        string="Appliquer dans Odoo"
                        icon="fa-upload"
                        class="btn-success"
                        invisible="state != 'validated'"
                    />

                    <button
                        name="action_cancel"
                        type="object"
                        string="Annuler"
                        icon="fa-times"
                        class="btn-secondary"
                        invisible="state in ('cancel','exported')"
                    />

                    <button
                        name="action_reset_to_draft"
                        type="object"
                        string="Remettre en brouillon"
                        icon="fa-undo"
                        class="btn-warning"
                        groups="primetech_inventory_count.group_inventory_manager"
                        invisible="state not in ('review','validated','exported','cancel')"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,counting,review,validated,exported,cancel"

                    />

                </header>

                <sheet>


                    <!-- SMART BUTTONS -->

                    <div class="oe_button_box" name="button_box">

                        <button
                            name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list">
                            <field name="line_count"
                                   widget="statinfo"
                                   string="Lignes"/>
                        </button>

                        <button
                            name="action_view_products"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-cubes">
                            <field name="product_count"
                                   widget="statinfo"
                                   string="Produits"/>
                        </button>

                        <button
                            name="action_view_differences"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-warning">
                            <field name="difference_count"
                                   widget="statinfo"
                                   string="Écarts"/>
                        </button>

                        <button
                            name="action_view_missing"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-arrow-down">
                            <field name="missing_count"
                                   widget="statinfo"
                                   string="Manquants"/>
                        </button>

                        <button
                            name="action_view_excess"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-arrow-up">
                            <field name="excess_count"
                                   widget="statinfo"
                                   string="Surplus"/>
                        </button>

                        <button
                            name="action_view_lines"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-check">
                            <field name="validated_line_count"
                                   widget="statinfo"
                                   string="Validées"/>
                        </button>


                    </div>

                    <!-- TITRE -->

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- INFORMATIONS -->
                    <group>

                        <group>

                            <field name="date_count" readonly="is_locked"/>

                            <field name="warehouse_id" readonly="is_locked"/>

                            <field
                                name="location_id"
                                domain="[('id','in',allowed_location_ids)]"
                                readonly="is_locked"/>
                            

                        </group>

                        <group>

                            <field name="user_id" readonly="1"/>

                            <field name="export_mode"
                                    readonly="is_locked"/>

                            <field
                                name="validated_by"
                                readonly="1"
                            />

                            <field
                                name="validation_date"
                                readonly="1"
                            />

                        </group>

                    </group>

                    <field name="record_id" invisible ="1" readonly="1"/>
                    

                    <!-- ZONE SCANNER -->

                    <separator
                        string="SCAN RAPIDE PRODUIT"
                        invisible="not location_id or state in ('validated','exported','cancel')"
                    />

                    <group
                        col="12"
                        class="pt_inventory_scan_bar"
                        invisible="not location_id or state in ('validated','exported','cancel')">

                        <widget name="primetech_barcode_scanner"/>

                    </group>

          

                    <!-- LIGNES -->
                    <div
                        class="alert alert-warning"
                        invisible="location_id">

                        Veuillez sélectionner un emplacement avant de saisir les lignes.

                    </div>
                    <field
                        name="line_ids"
                        nolabel="1"
                        invisible="not location_id"
                        readonly="is_locked">
                        

                        <list editable="top" create="not is_locked">

                            <field
                                name="barcode"
                                readonly="1"
                                optional="show"/>

                            <field name="product_id"/>

                            <field
                                name="count_location_id"
                                domain="[('id','in',allowed_location_ids)]"
                            />

                            <field
                                name="lot_id"
                                context="{
                                    'default_product_id': product_id
                                }"
                            />

                            <field name="expiration_date"/>

                            <field name="qty_system" readonly="1"/>

                            <field name="qty_counted"/>

                            <field name="difference"
                                   readonly="1"/>

                            <field name="difference_type"
                                   widget="badge"/>

                            

                            <field name="note"/>

                            <!-- Colonnes optionnelles -->

                            <field name="tracking"
                                   optional="hide"/>

                            <field name="system_location_id"
                                   optional="hide"/>

                            <field name="difference_percent"
                                   optional="hide"/>

                            <field name="location_difference"
                                   optional="hide"/>

                            <field name="is_manual"
                                   optional="hide"/>

                        </list>

                    </field>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>