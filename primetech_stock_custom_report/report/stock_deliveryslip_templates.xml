<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="primetech_report_delivery_document"
          inherit_id="stock.report_delivery_document">

    <xpath expr="//t[@t-call='web.external_layout']" position="replace">

        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o._get_report_lang())"/>

            <!-- ========================= -->
            <!-- TYPE DOCUMENT DYNAMIQUE -->
            <!-- ========================= -->
          <t t-set="doc_title" t-value="'BORDEREAU DE LIVRAISON'"/>
        <t t-set="doc_color" t-value="'#0d6efd'"/>

        <t t-if="o.picking_type_id.code == 'internal'">
            <t t-set="doc_title" t-value="'BORDEREAU DE TRANSFERT'"/>
            <t t-set="doc_color" t-value="'#fd7e14'"/>
        </t>

        <t t-if="o.picking_type_id.code == 'incoming'">
            <t t-set="doc_title" t-value="'BON DE RÉCEPTION'"/>
            <t t-set="doc_color" t-value="'#198754'"/>
        </t>

        <t t-if="o.origin and 'return' in (o.origin or '').lower()">
            <t t-set="doc_title" t-value="'BON DE RETOUR'"/>
            <t t-set="doc_color" t-value="'#dc3545'"/>
        </t>
            <div class="page" style="font-family: 'Roboto', Arial, sans-serif !important; font-size: 14px;">

                <!-- ========================= -->
                <!-- HEADER -->
                <!-- ========================= -->
                <div class="row mb-4">

                    <div class="col-6">

                        <div t-if="o.company_id.street">
                            <span t-field="o.company_id.street"/>
                        </div>

                        <div>
                            <span t-field="o.company_id.city"/>
                            <t t-if="o.company_id.city and o.company_id.country_id"> - </t>
                            <span t-field="o.company_id.country_id"/>
                        </div>

                        <div t-if="o.company_id.phone">
                            <strong>Tél :</strong>
                            <span t-field="o.company_id.phone"/>
                        </div>

                        <div t-if="o.company_id.email">
                            <strong>Email :</strong>
                            <span t-field="o.company_id.email"/>
                        </div>

                        <div t-if="o.company_id.website">
                            <strong>Web :</strong>
                            <span t-field="o.company_id.website"/>
                        </div>
                    </div>

                    <div class="col-6 text-end">

                        <div class="p-2 rounded text-center"
                            t-att-style="'background-color:' + doc_color + '; color:white !important;'">

                            <h3 class="m-0" style="color:white !important;">
                                <span t-esc="doc_title"/>
                            </h3>

                        </div>

                        <div class="mt-3">
                            <strong>N° :</strong>
                            <span t-field="o.name"/>
                        </div>

                        <div>
                            <strong>Date :</strong>
                            <span t-field="o.date_done"/>
                        </div>

                    </div>

                </div>

                <!-- ========================= -->
                <!-- ENTREPÔTS (DYNAMIQUE) -->
                <!-- ========================= -->
                <div class="row mb-3">
                <div class="col-6">

                    <strong>
                        <t t-if="o.picking_type_id.code == 'incoming'">
                            Entrepôt source :
                        </t>
                        <t t-else="">
                            Entrepôt source :
                        </t>
                    </strong>

                    <div>
                        <t t-if="o.picking_type_id.code == 'incoming'">
                            <span t-field="o.partner_id.name"/>
                            <t t-if="o.partner_id.city"> - <span t-field="o.partner_id.city"/></t>
                            <t t-if="o.partner_id.country_id"> - <span t-field="o.partner_id.country_id"/></t>
                        </t>

                        <t t-if="o.location_id.warehouse_id">
                            <span t-field="o.location_id.warehouse_id.name"/>
                            /
                        </t>
                        <span t-field="o.location_id.complete_name"/>
                    </div>

                </div>

                    <div class="col-6">
                        <strong>
                            <t t-if="o.picking_type_id.code == 'outgoing'">
                                Entrepôt de livraison :
                            </t>
                            <t t-else="">
                                Entrepôt destination :
                            </t>
                        </strong>

                        <div>
                            <t t-if="o.picking_type_id.code == 'outgoing'">
                                Client
                                :
                                <span t-field="o.partner_id.name"/>
                            </t>

                            <t t-else="">
                                <span t-field="o.location_dest_id.complete_name"/>
                            </t>
                        </div>
                    </div>

                </div>

                <!-- ========================= -->
                <!-- CLIENT -->
                <!-- ========================= -->
                <t t-set="type" t-value="o.picking_type_id.code"/>

                <t t-if="type != 'internal'">

                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="border rounded p-3">

                                <!-- TITRE -->
                                <h5 class="text-primary">

                                    <t t-if="type == 'incoming'">
                                        FOURNISSEUR
                                    </t>

                                    <t t-elif="type == 'outgoing'">
                                        CLIENT
                                    </t>

                                    <t t-elif="'return' in (o.origin or '').lower()">
                                        CLIENT
                                    </t>

                                </h5>

                                <!-- NOM -->
                                <div>
                                    <strong>
                                        <span t-field="o.partner_id.name"/>
                                    </strong>
                                </div>

                                <!-- ADRESSE -->
                                <div t-field="o.partner_id"
                                    t-options="{
                                        'widget':'contact',
                                        'fields':['address'],
                                        'no_marker':True
                                    }"/>

                                <!-- INFOS SUPPLÉMENTAIRES -->
                                <div class="mt-2">

                                    <div t-if="o.partner_id.phone">
                                        <strong>Téléphone :</strong>
                                        <span t-field="o.partner_id.phone"/>
                                    </div>

                                    <div t-if="o.partner_id.mobile">
                                        <strong>Mobile :</strong>
                                        <span t-field="o.partner_id.mobile"/>
                                    </div>

                                    <div t-if="o.partner_id.email">
                                        <strong>Email :</strong>
                                        <span t-field="o.partner_id.email"/>
                                    </div>

                                    <div t-if="o.partner_id.city">
                                        <strong>Ville :</strong>
                                        <span t-field="o.partner_id.city"/>
                                    </div>

                                    <div t-if="o.partner_id.country_id">
                                        <strong>Pays :</strong>
                                        <span t-field="o.partner_id.country_id"/>
                                    </div>

                                </div>

                            </div>
                        </div>
                    </div>

                </t>

                <!-- ========================= -->
                <!-- INFOS -->
                <!-- ========================= -->
                <div class="row mb-4">

                    <div class="col-4">
                        <strong>Référence :</strong>
                        <div t-field="o.origin"/>
                    </div>

                    <div class="col-4">
                        <strong>Statut :</strong>
                        <div t-field="o.state"/>
                    </div>

                    <div class="col-4">
                        <strong>Type :</strong>
                        <div t-field="o.picking_type_id.name"/>
                    </div>

                </div>
                

                    <!-- ========================================================= -->
                    <!-- PRODUITS -->
                    <!-- ========================================================= -->

                    <table class="table table-sm mb-0"
                        style="
                                width:100%;
                                table-layout:fixed;
                                border-collapse:collapse;
                        ">

                        <thead>

                            <tr style="
                                background:#1F4E79;
                                color:white;
                            ">

                                <!-- Produit -->

                                <th style="
                                    width:34%;
                                    color:white;
                                    padding:8px;
                                ">
                                    PRODUIT
                                </th>



                                <!-- Quantité commandée -->

                                <th style="
                                    width:14%;
                                    color:white;
                                    text-align:center;
                                    padding:8px;
                                ">
                                    QTE COMMANDE
                                </th>

                                <!-- Quantité livrée -->

                                <th style="
                                    width:14%;
                                    color:white;
                                    text-align:center;
                                    padding:8px;
                                ">
                                    QTE LIVREE
                                </th>

                                <!-- Lot -->

                                <th t-if="any(o.move_line_ids.mapped('lot_id'))"
                                    style="
                                        width:12%;
                                        color:white;
                                        text-align:center;
                                        padding:8px;
                                    ">
                                    Lot / Série
                                </th>

                                <!-- Expiration -->

                                <th t-if="any(o.move_line_ids.filtered(lambda l: l.lot_id and l.lot_id.use_date))"
                                    style="
                                        width:10%;
                                        color:white;
                                        text-align:center;
                                        padding:8px;
                                    ">
                                    Expiration
                                </th>

                            </tr>

                        </thead>

                        
                        <tbody>

                            <tr t-foreach="o.move_ids"
                                t-as="line"
                                style="border-bottom:1px solid #ECECEC;">

                                <t t-set="ml"
                                t-value="line.move_line_ids[:1] and line.move_line_ids[0]"/>

                                <!-- ================================================= -->
                                <!-- PRODUIT -->
                                <!-- ================================================= -->

                                <td style="
                                    padding:7px;
                                    vertical-align:top;
                                ">

                                    <div style="
                                        font-size:13px;
                                        font-weight:600;
                                        color:#2F3B4A;
                                    ">

                                        <span t-field="line.product_id"/>

                                    </div>

                                    <div t-if="line.product_id.default_code"
                                        style="
                                            font-size:10px;
                                            color:#6C757D;
                                            margin-top:2px;
                                        ">

                                        Réf :

                                        <span t-field="line.product_id.default_code"/>

                                    </div>

                                </td>

                
                                <!-- ================================================= -->
                                <!-- QTÉ COMMANDÉE -->
                                <!-- ================================================= -->

                                <td style="
                                    text-align:center;
                                    vertical-align:middle;
                                    padding:7px;
                                    ">

                                    <t t-if="line.product_packaging_id">

                                        <div style="
                                            font-size:12px;
                                            font-weight:600;
                                            color:#2F3B4A;
                                            line-height:18px;
                                        ">

                                            <span t-esc="('{:,.10f}'.format(line.packaging_qty)).rstrip('0').rstrip('.').replace(',', ' ')"/>

                                            <span t-field="line.packaging_name"/>

                                        </div>

                                        <t t-if="line.has_remaining">

                                            <div style="
                                                font-size:11px;
                                                color:#6C757D;
                                                margin-top:2px;
                                                line-height:16px;
                                            ">

                                                +

                                                <span t-esc="('{:,.10f}'.format(line.remaining_qty)).rstrip('0').rstrip('.').replace(',', ' ')"/>

                                                <span t-field="line.remaining_name"/>

                                            </div>

                                        </t>

                                    </t>

                                    <t t-else="">

                                        <div style="
                                            font-size:12px;
                                            font-weight:600;
                                            color:#2F3B4A;
                                        ">

                                            <span t-esc="('{:,.10f}'.format(line.product_uom_qty)).rstrip('0').rstrip('.').replace(',', ' ')"/>

                                            <span t-field="line.product_uom"/>

                                        </div>

                                    </t>

                                </td>

                                <!-- ================================================= -->
                                <!-- QTÉ LIVRÉE -->
                                <!-- ================================================= -->

                                <td style="
                                    text-align:center;
                                    vertical-align:middle;
                                    padding:7px;
                                    ">

                                    <t t-if="line.product_packaging_id and (line.done_packaging_qty or line.done_has_remaining)">

                                        <!-- Conditionnement -->

                                        <div style="
                                            font-size:12px;
                                            font-weight:700;
                                            color:#198754;
                                            line-height:18px;
                                        ">

                                            <t t-if="line.done_packaging_qty">

                                                <span t-esc="('{:,.10f}'.format(line.done_packaging_qty)).rstrip('0').rstrip('.').replace(',', ' ')"/>

                                                <span t-field="line.done_packaging_name"/>

                                            </t>

                                        </div>

                                        <!-- Reste -->

                                        <t t-if="line.done_has_remaining">

                                            <div style="
                                                font-size:11px;
                                                color:#6C757D;
                                                margin-top:2px;
                                                line-height:16px;
                                            ">

                                                +

                                                <span t-esc="('{:,.10f}'.format(line.done_remaining_qty)).rstrip('0').rstrip('.').replace(',', ' ')"/>

                                                <span t-field="line.done_remaining_name"/>

                                            </div>

                                        </t>

                                    </t>

                                    <!-- Affichage simple -->

                                    <t t-else="">

                                        <div style="
                                            font-size:12px;
                                            font-weight:700;
                                            color:#198754;
                                        ">

                                            <span t-esc="('{:,.10f}'.format(sum(line.move_line_ids.mapped('quantity')))).rstrip('0').rstrip('.').replace(',', ' ')"/>

                                            <span t-field="line.product_uom"/>

                                        </div>

                                    </t>

                                </td>


                                <!-- ================================================= -->
                                <!-- LOT / SÉRIE -->
                                <!-- ================================================= -->

                                <t t-if="any(o.move_ids.mapped('move_line_ids.lot_id'))">

                                    <td style="
                                        text-align:center;
                                        vertical-align:middle;
                                        padding:7px;
                                        ">

                                        <t t-if="ml and ml.lot_id">

                                            <span style="
                                                display:inline-block;
                                                padding:4px 10px;
                                                background:#E7F1FF;
                                                color:#0D6EFD;
                                                border-radius:12px;
                                                font-size:11px;
                                                font-weight:600;
                                                white-space:nowrap;
                                            ">

                                                <span t-field="ml.lot_id.name"/>

                                            </span>

                                        </t>

                                        <t t-else="">

                                            <span class="text-muted">

                                                —

                                            </span>

                                        </t>

                                    </td>

                                </t>

                                <!-- ================================================= -->
                                <!-- DATE DE PÉREMPTION -->
                                <!-- ================================================= -->

                                <t t-if="any(o.move_ids.mapped('move_line_ids.lot_id.use_date'))">

                                    <td style="
                                        text-align:center;
                                        vertical-align:middle;
                                        padding:7px;
                                    ">

                                        <t t-if="ml and ml.lot_id and ml.lot_id.use_date">

                                            <span style="
                                                color:#DC3545;
                                                font-size:11px;
                                                font-weight:600;
                                                white-space:nowrap;
                                            ">

                                                <span t-field="ml.lot_id.use_date"
                                                    t-options='{"format":"dd/MM/yyyy"}'/>

                                            </span>

                                        </t>

                                        <t t-else="">

                                            <span class="text-muted">

                                                —

                                            </span>

                                        </t>

                                    </td>

                                </t>

                            </tr>

                        </tbody>

                    </table>

                    <!-- ============================================= -->
                    <!-- STYLE PREMIUM -->
                    <!-- ============================================= -->

                    <style>

                        table.table-sm tbody tr:nth-child(even){
                            background:#FCFCFC;
                        }

                        table.table-sm tbody tr:hover{
                            background:#F7FAFD;
                        }

                        table.table-sm td{
                            padding-top:7px;
                            padding-bottom:7px;
                        }

                        table.table-sm th{
                            font-size:12px;
                            font-weight:700;
                        }

                        table.table-sm td{
                            font-size:11px;
                        }

                    </style>



                <!-- ========================= -->
                <!-- OBSERVATIONS -->
                <!-- ========================= -->
                <div class="mt-4">
                    <strong>Observations :</strong>
                    <div class="border rounded p-3" style="min-height:60px;"></div>
                </div>

                <!-- ========================= -->
                <!-- SIGNATURES -->
                <!-- ========================= -->
                <div class="row mt-5" style="font-size:18px;">

                    <div class="col-6 text-center">
                        <div style="height:80px;"></div>
                        <strong style="font-size:22px;">Le Magasinier</strong>
                    </div>

                    <div class="col-6 text-center">
                        <div style="height:80px;"></div>

                        <strong style="font-size:22px;">

                            <t t-if="o.picking_type_id.code == 'incoming'">
                                Fournisseur / Représentant
                            </t>

                            <t t-elif="o.picking_type_id.code == 'outgoing'">
                                Le Client
                            </t>

                            <!-- internal = transfert => rien -->
                        </strong>

                    </div>

                </div>

            </div>

        </t>

    </xpath>

</template>

</odoo>