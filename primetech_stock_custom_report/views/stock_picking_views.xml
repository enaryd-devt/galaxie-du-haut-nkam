<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_picking_form_packaging_qty"
            model="ir.ui.view">

        <field name="name">stock.picking.form.packaging.qty</field>

        <field name="model">stock.picking</field>

        <field name="inherit_id"
               ref="stock.view_picking_form"/>

        <field name="arch"
               type="xml">

            <xpath expr="//field[@name='move_ids_without_package']/list/field[@name='product_packaging_id']"
                   position="after">

                <field name="packaging_qty"
                       string="Nb Cond."/>

            </xpath>

        </field>

    </record>

</odoo>