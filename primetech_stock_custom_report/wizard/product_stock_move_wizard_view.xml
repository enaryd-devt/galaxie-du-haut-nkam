<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_stock_move_wizard_form" model="ir.ui.view">
        <field name="name">product.stock.move.wizard.form</field>
        <field name="model">product.stock.move.wizard</field>

        <field name="arch" type="xml">
            <form string="📦 Imprimer mouvements de stock">

                <sheet>

                    <!-- ===================== -->
                    <!-- PRODUIT (depuis fiche) -->
                    <!-- ===================== -->
                    <group>
                        <field name="product_tmpl_id"
                               readonly="1"
                               invisible="not product_tmpl_id"/>
                    </group>

                    <!-- ===================== -->
                    <!-- FILTRES ANALYSE -->
                    <!-- ===================== -->
                    <group string="Filtres Analyse"
                           invisible="product_tmpl_id">

                        <group>
                            <field name="category_ids"
                                   widget="many2many_tags"/>

                            <field name="product_ids"
                                   widget="many2many_tags"/>
                        </group>

                        <group>
                            <field name="move_type"/>
                        </group>

                    </group>

                    <!-- ===================== -->
                    <!-- PÉRIODE -->
                    <!-- ===================== -->
                    <group string="Période">
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>

                </sheet>

                <footer>

                    <button name="action_print_report"
                            type="object"
                            string="Imprimer"
                            class="btn-primary"/>

                    <button string="Annuler"
                            special="cancel"
                            class="btn-secondary"/>

                </footer>

            </form>
        </field>
    </record>

</odoo>