<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template
        id="stock_valuation_preview_template"
    >

        <div
            style="
                padding:20px;
                background:#f8fafc;
                font-family:Arial,sans-serif;
            "
        >

            <!-- ===================================== -->
            <!-- HEADER -->
            <!-- ===================================== -->

            <div
                style="
                    background:white;
                    border-radius:18px;
                    padding:20px;
                    margin-bottom:20px;
                    box-shadow:0 2px 8px rgba(0,0,0,.08);
                "
            >

                <div
                    style="
                        display:flex;
                        justify-content:space-between;
                        align-items:center;
                    "
                >

                    <div>

                        <h2
                            style="
                                margin:0;
                                color:#111827;
                            "
                        >
                            Valorisation du Stock
                        </h2>

                        <div
                            style="
                                color:#6b7280;
                                margin-top:6px;
                            "
                        >
                            Analyse financière des stocks
                        </div>

                    </div>

                    <div
                        style="
                            text-align:right;
                        "
                    >

                        <div>

                            Généré le

                        </div>

                        <strong>

                            <t
                                t-esc="
                                    generated_at
                                "
                            />

                        </strong>

                    </div>

                </div>

            </div>

            <!-- ===================================== -->
            <!-- KPI -->
            <!-- ===================================== -->

            <div
                style="
                    display:flex;
                    gap:15px;
                    margin-bottom:20px;
                "
            >

                <!-- KPI 1 -->

                <div
                    style="
                        flex:1;
                        background:white;
                        padding:18px;
                        border-radius:16px;
                        box-shadow:0 2px 8px rgba(0,0,0,.05);
                    "
                >

                    <div
                        style="
                            color:#6b7280;
                            font-size:12px;
                        "
                    >
                        Produits
                    </div>

                    <div
                        style="
                            font-size:24px;
                            font-weight:700;
                            margin-top:8px;
                        "
                    >

                        <t
                            t-esc="
                                data['kpi']['products_count']
                            "
                        />

                    </div>

                </div>

                <!-- KPI 2 -->

                <div
                    style="
                        flex:1;
                        background:white;
                        padding:18px;
                        border-radius:16px;
                        box-shadow:0 2px 8px rgba(0,0,0,.05);
                    "
                >

                    <div
                        style="
                            color:#6b7280;
                            font-size:12px;
                        "
                    >
                        Quantité Totale
                    </div>

                    <div
                        style="
                            font-size:24px;
                            font-weight:700;
                            margin-top:8px;
                        "
                    >

                        <t
                            t-out="
                                '{:,.2f}'.format(
                                    data['kpi']['total_qty']
                                )
                            "
                        />

                    </div>

                </div>

                <!-- KPI 3 -->

                <div
                    style="
                        flex:1;
                        background:white;
                        padding:18px;
                        border-radius:16px;
                        box-shadow:0 2px 8px rgba(0,0,0,.05);
                    "
                >

                    <div
                        style="
                            color:#6b7280;
                            font-size:12px;
                        "
                    >
                        Valeur du Stock
                    </div>

                    <div
                        style="
                            font-size:24px;
                            font-weight:700;
                            color:#16a34a;
                            margin-top:8px;
                        "
                    >

                        <t
                            t-out="
                                '{:,.2f}'.format(
                                    data['kpi']['stock_value']
                                )
                            "
                        />

                    </div>

                </div>

                <!-- KPI 4 -->

                <div
                    style="
                        flex:1;
                        background:white;
                        padding:18px;
                        border-radius:16px;
                        box-shadow:0 2px 8px rgba(0,0,0,.05);
                    "
                >

                    <div
                        style="
                            color:#6b7280;
                            font-size:12px;
                        "
                    >
                        Coût Moyen
                    </div>

                    <div
                        style="
                            font-size:24px;
                            font-weight:700;
                            margin-top:8px;
                        "
                    >

                        <t
                            t-out="
                                '{:,.2f}'.format(
                                    data['kpi']['average_cost']
                                )
                            "
                        />

                    </div>

                </div>

            </div>
                        <!-- ===================================== -->
            <!-- TOP PRODUIT -->
            <!-- ===================================== -->

            <div
                style="
                    background:white;
                    border-radius:18px;
                    padding:20px;
                    margin-bottom:20px;
                    box-shadow:0 2px 8px rgba(0,0,0,.05);
                "
            >

                <div
                    style="
                        display:flex;
                        justify-content:space-between;
                        align-items:center;
                    "
                >

                    <div>

                        <div
                            style="
                                color:#6b7280;
                                font-size:12px;
                            "
                        >
                            Produit le Plus Valorisé
                        </div>

                        <div
                            style="
                                font-size:20px;
                                font-weight:700;
                                margin-top:8px;
                            "
                        >

                            <t
                                t-esc="
                                    data['kpi']['top_product']
                                "
                            />

                        </div>

                    </div>

                    <div
                        style="
                            font-size:24px;
                            font-weight:700;
                            color:#16a34a;
                        "
                    >

                        <t
                            t-out="
                                '{:,.2f}'.format(
                                    data['kpi']['top_product_value']
                                )
                            "
                        />

                    </div>

                </div>

            </div>

            <!-- ===================================== -->
            <!-- TABLEAU -->
            <!-- ===================================== -->

            <div
                style="
                    background:white;
                    border-radius:18px;
                    padding:20px;
                    box-shadow:0 2px 8px rgba(0,0,0,.05);
                "
            >

                <table
                    style="
                        width:100%;
                        border-collapse:collapse;
                    "
                >

                    <thead>

                        <tr
                            style="
                                background:#f3f4f6;
                            "
                        >

                            <th class="pt_th">
                                Produit
                            </th>

                            <th class="pt_th">
                                Référence
                            </th>

                            <th class="pt_th">
                                Catégorie
                            </th>

                            <th class="pt_th">
                                Quantité
                            </th>

                            <th class="pt_th">
                                Coût Unitaire
                            </th>

                            <th class="pt_th">
                                Valeur Stock
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        <t
                            t-foreach="
                                data['lines']
                            "
                            t-as="line"
                        >

                            <tr>

                                <td class="pt_td">

                                    <strong>

                                        <t
                                            t-esc="
                                                line['product_name']
                                            "
                                        />

                                    </strong>

                                </td>

                                <td class="pt_td">

                                    <t
                                        t-esc="
                                            line['default_code']
                                        "
                                    />

                                </td>

                                <td class="pt_td">

                                    <t
                                        t-esc="
                                            line['category']
                                        "
                                    />

                                </td>

                                <td
                                    class="pt_td"
                                    style="
                                        text-align:right;
                                    "
                                >

                                    <t
                                        t-out="
                                            '{:,.2f}'.format(
                                                line['quantity']
                                            )
                                        "
                                    />

                                </td>

                                <td
                                    class="pt_td"
                                    style="
                                        text-align:right;
                                    "
                                >

                                    <t
                                        t-out="
                                            '{:,.2f}'.format(
                                                line['cost_price']
                                            )
                                        "
                                    />

                                </td>

                                <td
                                    class="pt_td"
                                    style="
                                        text-align:right;
                                        font-weight:700;
                                        color:#16a34a;
                                    "
                                >

                                    <t
                                        t-out="
                                            '{:,.2f}'.format(
                                                line['stock_value']
                                            )
                                        "
                                    />

                                </td>

                            </tr>

                        </t>

                    </tbody>

                    <tfoot>

                        <tr
                            style="
                                background:#f9fafb;
                                font-weight:700;
                            "
                        >

                            <td
                                colspan="3"
                                class="pt_td"
                                style="
                                    text-align:right;
                                "
                            >

                                TOTAL

                            </td>

                            <td
                                class="pt_td"
                                style="
                                    text-align:right;
                                "
                            >

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            data['kpi']['total_qty']
                                        )
                                    "
                                />

                            </td>

                            <td
                                class="pt_td"
                            />

                            <td
                                class="pt_td"
                                style="
                                    text-align:right;
                                    color:#16a34a;
                                "
                            >

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            data['kpi']['stock_value']
                                        )
                                    "
                                />

                            </td>

                        </tr>

                    </tfoot>

                </table>

            </div>

            <!-- ===================================== -->
            <!-- OBSERVATIONS -->
            <!-- ===================================== -->

            <t
                t-if="
                    wizard.observations
                "
            >

                <div
                    style="
                        margin-top:20px;
                        background:white;
                        border-radius:18px;
                        padding:20px;
                        box-shadow:0 2px 8px rgba(0,0,0,.05);
                    "
                >

                    <h4
                        style="
                            margin-top:0;
                        "
                    >
                        Observations
                    </h4>

                    <div>

                        <t
                            t-esc="
                                wizard.observations
                            "
                        />

                    </div>

                </div>

            </t>

            <!-- ===================================== -->
            <!-- STYLE -->
            <!-- ===================================== -->

            <style>

                .pt_th{
                    border:1px solid #e5e7eb;
                    padding:10px;
                    text-align:left;
                    font-size:12px;
                    font-weight:700;
                }

                .pt_td{
                    border:1px solid #e5e7eb;
                    padding:10px;
                    font-size:12px;
                }

            </style>

        </div>

    </template>

</odoo>