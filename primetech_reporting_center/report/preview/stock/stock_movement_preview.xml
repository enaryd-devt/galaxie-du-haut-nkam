<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template
        id="stock_movement_preview_template"
    >

        <div
            style="
                padding:20px;
                background:white;
                color:black;
                font-family:Arial,sans-serif;
            "
        >

            <!-- ===================================== -->
            <!-- ENTETE -->
            <!-- ===================================== -->

            <div
                style="
                    border:2px solid black;
                    padding:15px;
                    margin-bottom:20px;
                "
            >

                <h2
                    style="
                        margin:0;
                        color:black;
                    "
                >

                    MOUVEMENTS DE STOCK

                </h2>

                <div
                    style="
                        margin-top:10px;
                    "
                >

                    Société :

                    <strong>

                        <t
                            t-esc="
                                wizard.company_id.name
                            "
                        />

                    </strong>

                </div>

                <div>

                    Période :

                    <strong>

                        <t
                            t-esc="
                                wizard.date_from
                            "
                        />

                        →

                        <t
                            t-esc="
                                wizard.date_to
                            "
                        />

                    </strong>

                </div>

            </div>

            <!-- ===================================== -->
            <!-- KPI -->
            <!-- ===================================== -->

            <table
                style="
                    width:100%;
                    border-collapse:collapse;
                    margin-bottom:20px;
                "
            >

                <tr>

                    <td class="kpi">

                        Produits

                        <br/>

                        <strong>

                            <t
                                t-esc="
                                    data['kpi']['products_count']
                                "
                            />

                        </strong>

                    </td>

                    <td class="kpi">

                        Mouvements

                        <br/>

                        <strong>

                            <t
                                t-esc="
                                    data['kpi']['movements_count']
                                "
                            />

                        </strong>

                    </td>

                    <td class="kpi">

                        Lots

                        <br/>

                        <strong>

                            <t
                                t-esc="
                                    data['kpi']['lots_count']
                                "
                            />

                        </strong>

                    </td>

                    <td class="kpi">

                        Entrées

                        <br/>

                        <strong>

                            <t
                                t-esc="
                                    data['kpi']['total_entries']
                                "
                            />

                        </strong>

                    </td>

                    <td class="kpi">

                        Sorties

                        <br/>

                        <strong>

                            <t
                                t-esc="
                                    data['kpi']['total_outputs']
                                "
                            />

                        </strong>

                    </td>

                </tr>

            </table>
                        <!-- ===================================== -->
            <!-- PRODUITS -->
            <!-- ===================================== -->

            <t
                t-foreach="data['products']"
                t-as="product"
            >

                <div
                    style="
                        margin-top:25px;
                        border:2px solid black;
                        padding:12px;
                        page-break-inside:avoid;
                    "
                >

                    <!-- ============================== -->
                    <!-- TITRE PRODUIT -->
                    <!-- ============================== -->

                    <div
                        style="
                            font-size:18px;
                            font-weight:bold;
                            margin-bottom:10px;
                        "
                    >

                        <t
                            t-esc="
                                product['product_name']
                            "
                        />

                    </div>

                    <!-- ============================== -->
                    <!-- INFOS PRODUIT -->
                    <!-- ============================== -->

                    <table
                        style="
                            width:100%;
                            border-collapse:collapse;
                            margin-bottom:15px;
                        "
                    >

                        <tr>

                            <td width="25%">

                                <strong>
                                    Référence
                                </strong>

                            </td>

                            <td width="25%">

                                <t
                                    t-esc="
                                        product['default_code']
                                    "
                                />

                            </td>

                            <td width="25%">

                                <strong>
                                    Catégorie
                                </strong>

                            </td>

                            <td width="25%">

                                <t
                                    t-esc="
                                        product['category_name']
                                    "
                                />

                            </td>

                        </tr>

                        <tr>

                            <td>

                                <strong>
                                    Stock Final
                                </strong>

                            </td>

                            <td>

                                <t
                                    t-esc="
                                        product['balance']
                                    "
                                />

                            </td>

                            <td>

                                <strong>
                                    Valorisation
                                </strong>

                            </td>

                            <td>

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            product['valuation']
                                        )
                                    "
                                />

                            </td>

                        </tr>

                    </table>

                    <!-- ============================== -->
                    <!-- TABLEAU -->
                    <!-- ============================== -->

                    <table
                        class="movement_table"
                        style="
                            width:100%;
                            border-collapse:collapse;
                        "
                    >

                        <thead>

                            <tr>

                                <th>
                                    Date
                                </th>

                                <th>
                                    Partenaire
                                </th>

                                <th>
                                    Document
                                </th>

                                <th>
                                    Origine
                                </th>

                                <th>
                                    Destination
                                </th>

                                <th>
                                    Lot
                                </th>

                                <th>
                                    Entrée
                                </th>

                                <th>
                                    Sortie
                                </th>

                                <th>
                                    Solde
                                </th>

                                <th t-if="wizard.show_cost">
                                    Coût
                                </th>

                                <th t-if="wizard.show_valuation">
                                    Valorisation
                                </th>

                            </tr>

                        </thead>

                        <tbody>
                            <t
    t-foreach="product['lines']"
    t-as="line"
>

    <tr
        t-att-style="
            'background:#ecfdf5;color:#166534;'
            if line['is_entry']
            else
            'background:#fef2f2;color:#991b1b;'
        "
    >

        <!-- ============================== -->
        <!-- DATE -->
        <!-- ============================== -->

        <td>

            <t
                t-out="
                    line['date'].strftime(
                        '%d/%m/%Y %H:%M'
                    )
                    if line['date']
                    else ''
                "
            />

        </td>

        <!-- ============================== -->
        <!-- PARTENAIRE -->
        <!-- ============================== -->

        <td>

            <t
                t-esc="
                    line['partner_name']
                "
            />

        </td>

        <!-- ============================== -->
        <!-- DOCUMENT -->
        <!-- ============================== -->

        <td>

            <t
                t-esc="
                    line['document']
                "
            />

        </td>

        <!-- ============================== -->
        <!-- ORIGINE -->
        <!-- ============================== -->

        <td>

            <t
                t-esc="
                    line['source_name']
                "
            />

        </td>

        <!-- ============================== -->
        <!-- DESTINATION -->
        <!-- ============================== -->

        <td>

            <t
                t-esc="
                    line['destination_name']
                "
            />

        </td>

        <!-- ============================== -->
        <!-- LOT -->
        <!-- ============================== -->

        <td>

            <t
                t-esc="
                    line['lot_name']
                "
            />

        </td>

        <!-- ============================== -->
        <!-- ENTREE -->
        <!-- ============================== -->

        <td
            style="
                text-align:right;
            "
        >

            <t
                t-if="
                    line['qty_in']
                "
            >

                <t
                    t-out="
                        '{:,.2f}'.format(
                            line['qty_in']
                        )
                    "
                />

            </t>

        </td>

        <!-- ============================== -->
        <!-- SORTIE -->
        <!-- ============================== -->

        <td
            style="
                text-align:right;
            "
        >

            <t
                t-if="
                    line['qty_out']
                "
            >

                <t
                    t-out="
                        '{:,.2f}'.format(
                            line['qty_out']
                        )
                    "
                />

            </t>

        </td>

        <!-- ============================== -->
        <!-- SOLDE -->
        <!-- ============================== -->

        <td
            style="
                text-align:right;
                font-weight:bold;
            "
        >

            <t
                t-out="
                    '{:,.2f}'.format(
                        line['balance']
                    )
                "
            />

        </td>

        <!-- ============================== -->
        <!-- COUT -->
        <!-- ============================== -->

        <td
            t-if="
                wizard.show_cost
            "
            style="
                text-align:right;
            "
        >

            <t
                t-out="
                    '{:,.2f}'.format(
                        line['cost']
                    )
                "
            />

        </td>

        <!-- ============================== -->
        <!-- VALORISATION -->
        <!-- ============================== -->

        <td
            t-if="
                wizard.show_valuation
            "
            style="
                text-align:right;
            "
        >

            <t
                t-out="
                    '{:,.2f}'.format(
                        line['valuation']
                    )
                "
            />

        </td>

    </tr>

</t>

                        </tbody>

                    </table>
                                        <!-- ============================== -->
                    <!-- TOTAL ARTICLE -->
                    <!-- ============================== -->

                    <table
                        style="
                            width:100%;
                            margin-top:10px;
                            border-collapse:collapse;
                        "
                    >

                        <tr>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    font-weight:bold;
                                    background:#f2f2f2;
                                "
                            >

                                Total Entrées

                            </td>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    text-align:right;
                                "
                            >

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            product['total_in']
                                        )
                                    "
                                />

                            </td>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    font-weight:bold;
                                    background:#f2f2f2;
                                "
                            >

                                Total Sorties

                            </td>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    text-align:right;
                                "
                            >

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            product['total_out']
                                        )
                                    "
                                />

                            </td>

                        </tr>

                        <tr>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    font-weight:bold;
                                    background:#f2f2f2;
                                "
                            >

                                Stock Final

                            </td>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    text-align:right;
                                "
                            >

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            product['balance']
                                        )
                                    "
                                />

                            </td>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    font-weight:bold;
                                    background:#f2f2f2;
                                "
                            >

                                Valeur Finale

                            </td>

                            <td
                                style="
                                    border:1px solid black;
                                    padding:8px;
                                    text-align:right;
                                "
                            >

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                            product['valuation']
                                        )
                                    "
                                />

                            </td>

                        </tr>

                    </table>
                                <!-- ============================== -->
            <!-- OBSERVATIONS -->
            <!-- ============================== -->

            <t
                t-if="wizard.observations"
            >

                <div
                    style="
                        margin-top:25px;
                        border:2px solid black;
                        padding:15px;
                    "
                >

                    <strong>

                        Observations

                    </strong>

                    <div
                        style="
                            margin-top:10px;
                        "
                    >

                        <t
                            t-esc="
                                wizard.observations
                            "
                        />

                    </div>

                </div>

            </t>

            <!-- ============================== -->
            <!-- STYLES -->
            <!-- ============================== -->

            <style>

                .kpi {

                    border:1px solid black;

                    text-align:center;

                    padding:10px;

                    font-size:12px;

                }

                .movement_table th {

                    border:1px solid black;

                    padding:6px;

                    background:#f2f2f2;

                    font-size:12px;

                }

                .movement_table td {

                    border:1px solid black;

                    padding:5px;

                    font-size:11px;

                }

            </style>

                </div>

            </t>
        </div>

    </template>

</odoo>