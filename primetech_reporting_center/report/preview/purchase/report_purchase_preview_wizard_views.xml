<?xml version="1.0" encoding="utf-8"?>

<odoo>


    <record
        id="view_purchase_preview_wizard_form"
        model="ir.ui.view">

        <field name="name">purchase.preview.wizard.form</field>

        <field name="model">primetech.purchase.preview.wizard</field>

        <field name="arch" type="xml">

            <form
                string="Aperçu du Rapport"
                create="0"
                edit="0"
                delete="0">

                <header>

                    <button
                        name="action_print_pdf"
                        type="object"
                        string="Imprimer PDF"
                        icon="fa-file-pdf-o"
                        class="btn-primary"/>

                    <button
                        name="action_export_xlsx"
                        type="object"
                        string="Exporter Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

        

                </header>

                <sheet>

                    <group>

                        <field
                            name="html"
                            widget="html"
                            readonly="1"
                            nolabel="1"/>

                    </group>

                </sheet>

            </form>

        </field>

    </record>


</odoo>
