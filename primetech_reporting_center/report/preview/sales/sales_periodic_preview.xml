<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record
        id="view_sales_preview_wizard"
        model="ir.ui.view">

        <field name="name">sales.preview.wizard.form</field>

        <field name="model">primetech.sales.preview.wizard</field>

        <field name="arch" type="xml">

            <form
                string="Prévisualisation du Rapport"
                create="0"
                edit="0"
                delete="0">

                <sheet>

                    <field name="name" readonly="1"/>

                    <field
                        name="html"
                        widget="html"
                        readonly="1"
                        nolabel="1"/>

                </sheet>

                <footer>

                    <button
                        name="action_print_pdf"
                        type="object"
                        string=" Imprimer PDF"
                        icon="fa-file-pdf-o"
                        class="btn-primary"/>

                    <button
                        name="action_export_xlsx"
                        type="object"
                        string=" Export Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

                    <button
                        name="action_back"
                        type="object"
                        string=" Retour"
                        icon="fa-arrow-left"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>