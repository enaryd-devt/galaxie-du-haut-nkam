<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <template id="stock_status_pdf_template">

    
    <t t-call="web.html_container">

        <t t-call="web.external_layout">

            <div class="page">

                <h2
                    style="
                        text-align:center;
                        margin-bottom:20px;
                    "
                >
                    ETAT DE STOCK
                </h2>

                <table
                    class="
                        table
                        table-sm
                        table-bordered
                    "
                >

                    <tr>

                        <td>
                            <strong>Date début</strong>
                        </td>

                        <td>
                            <t t-esc="filters.get('date_from', '')"/>
                        </td>

                        <td>
                            <strong>Date fin</strong>
                        </td>

                        <td>
                            <t t-esc="filters.get('date_to', '')"/>
                        </td>

                    </tr>

                </table>


                <h4>
                    Détail du Stock
                </h4>

                <table
                    class="
                        table
                        table-sm
                        table-bordered
                    "
                >

                    <thead>

                        <tr>

                            <th>Produit</th>

                            <th>Catégorie</th>

                            <th>Disponible</th>

                            <th>Réservé</th>

                            <th>Valeur</th>

                            <th>État</th>

                        </tr>

                    </thead>

                    <tbody>

                        <t
                            t-foreach="
                                report_data.get(
                                    'lines',
                                    []
                                )
                            "
                            t-as="line"
                        >

                            <tr>

                                <td>
                                    <t t-esc="line.get('product_name', '')"/>
                                </td>

                                <td>
                                    <t t-esc="line.get('category', '')"/>
                                </td>

                                <td>
                                    <t t-esc="line.get('available_qty', 0)"/>
                                </td>

                                <td>
                                    <t t-esc="line.get('reserved_qty', 0)"/>
                                </td>

                                <td>
                                    <t t-esc="line.get('value', 0)"/>
                                </td>

                                <td>
                                    <t t-esc="line.get('state', '')"/>
                                </td>

                            </tr>

                        </t>

                    </tbody>

                </table>

            </div>

        </t>

    </t>


    </template>


</odoo>