<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template
        id="stock_card_pdf_template"
    >

        <t t-call="web.html_container">

            <t t-call="web.external_layout">

                <div class="page">

                    <!-- ===================================== -->
                    <!-- TITRE -->
                    <!-- ===================================== -->

                    <div
                        style="
                            text-align:center;
                            margin-bottom:20px;
                        "
                    >

                        <h2>

                            FICHE DE STOCK

                        </h2>

                    </div>

                    <!-- ===================================== -->
                    <!-- KPI -->
                    <!-- ===================================== -->

                    <table
                        style="
                            width:100%;
                            margin-bottom:20px;
                            border-collapse:collapse;
                        "
                    >

                        <tr>

                            <td
                                style="
                                    border:1px solid #000;
                                    padding:8px;
                                    text-align:center;
                                "
                            >

                                <strong>
                                    Articles
                                </strong>

                                <br/>

                                <t
                                    t-esc="
                                        report_data['kpi']['products_count']
                                    "
                                />

                            </td>

                            <td
                                style="
                                    border:1px solid #000;
                                    padding:8px;
                                    text-align:center;
                                "
                            >

                                <strong>
                                    Quantité
                                </strong>

                                <br/>

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                        report_data['kpi']['total_qty']
                                        )
                                    "
                                />

                            </td>

                            <td
                                style="
                                    border:1px solid #000;
                                    padding:8px;
                                    text-align:center;
                                "
                            >

                                <strong>
                                    Valeur Stock
                                </strong>

                                <br/>

                                <t
                                    t-out="
                                        '{:,.2f}'.format(
                                        report_data['kpi']['stock_value']
                                        )
                                    "
                                />

                            </td>

                        </tr>

                    </table>
                                        <!-- ===================================== -->
                    <!-- TABLEAU PRINCIPAL -->
                    <!-- ===================================== -->

                    <table
                        style="
                            width:100%;
                            border-collapse:collapse;
                            font-size:10px;
                        "
                    >

                        <thead>

                            <tr>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Article
                                </th>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Référence
                                </th>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Lots
                                </th>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Qté
                                </th>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Coût
                                </th>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Prix Vente
                                </th>

                                <th
                                    style="
                                        border:1px solid #000;
                                        padding:5px;
                                        background:#E5E7EB;
                                    "
                                >
                                    Valeur
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <t
                                t-foreach="report_data['lines']"
                                t-as="line"
                            >

                                <tr>

                                    <!-- ARTICLE -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                        "
                                    >

                                        <t
                                            t-esc="
                                                line['product_name']
                                            "
                                        />

                                    </td>

                                    <!-- REFERENCE -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                        "
                                    >

                                        <t
                                            t-esc="
                                                line['default_code']
                                            "
                                        />

                                    </td>

                                    <!-- LOTS -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                            vertical-align:top;
                                            min-width:180px;
                                        "
                                    >

                                        <t
                                            t-if="
                                                line['lots']
                                            "
                                        >

                                            <table
                                                style="
                                                    width:100%;
                                                    border-collapse:collapse;
                                                    font-size:9px;
                                                "
                                            >

                                                <thead>

                                                    <tr>

                                                        <th
                                                            style="
                                                                border:1px solid #000;
                                                                padding:2px;
                                                                background:#F3F4F6;
                                                            "
                                                        >
                                                            Lot
                                                        </th>

                                                        <th
                                                            style="
                                                                border:1px solid #000;
                                                                padding:2px;
                                                                text-align:right;
                                                                background:#F3F4F6;
                                                            "
                                                        >
                                                            Qté
                                                        </th>

                                                    </tr>

                                                </thead>

                                                <tbody>

                                                    <t
                                                        t-foreach="line['lots']"
                                                        t-as="lot"
                                                    >

                                                        <tr>

                                                            <td
                                                                style="
                                                                    border:1px solid #000;
                                                                    padding:2px;
                                                                "
                                                            >

                                                                <t
                                                                    t-esc="
                                                                        lot['lot_name']
                                                                    "
                                                                />

                                                            </td>

                                                            <td
                                                                style="
                                                                    border:1px solid #000;
                                                                    padding:2px;
                                                                    text-align:right;
                                                                "
                                                            >

                                                                <t
                                                                    t-out="
                                                                        '{:,.2f}'.format(
                                                                        lot['quantity']
                                                                        )
                                                                    "
                                                                />

                                                            </td>

                                                        </tr>

                                                    </t>

                                                </tbody>

                                            </table>

                                        </t>

                                        <t
                                            t-if="
                                                not line['lots']
                                            "
                                        >

                                            -

                                        </t>

                                    </td>
                                                                        <!-- QUANTITE -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                            text-align:right;
                                        "
                                    >

                                        <t
                                            t-out="
                                                '{:,.2f}'.format(
                                                line['quantity']
                                                )
                                            "
                                        />

                                    </td>

                                    <!-- COUT -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                            text-align:right;
                                        "
                                    >

                                        <t
                                            t-out="
                                                '{:,.2f}'.format(
                                                line['cost_price']
                                                )
                                            "
                                        />

                                    </td>

                                    <!-- PRIX VENTE -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                            text-align:right;
                                        "
                                    >

                                        <t
                                            t-out="
                                                '{:,.2f}'.format(
                                                line['sale_price']
                                                )
                                            "
                                        />

                                    </td>

                                    <!-- VALEUR -->

                                    <td
                                        style="
                                            border:1px solid #000;
                                            padding:4px;
                                            text-align:right;
                                            font-weight:bold;
                                        "
                                    >

                                        <t
                                            t-out="
                                                '{:,.2f}'.format(
                                                line['stock_value']
                                                )
                                            "
                                        />

                                    </td>

                                </tr>

                            </t>

                        </tbody>

                        <!-- ===================================== -->
                        <!-- TOTAL GENERAL -->
                        <!-- ===================================== -->

                        <tfoot>

                            <tr>

                                <td
                                    colspan="3"
                                    style="
                                        border:1px solid #000;
                                        padding:6px;
                                        font-weight:bold;
                                        text-align:right;
                                    "
                                >

                                    TOTAL GENERAL

                                </td>

                                <td
                                    style="
                                        border:1px solid #000;
                                        padding:6px;
                                        text-align:right;
                                        font-weight:bold;
                                    "
                                >

                                    <t
                                        t-out="
                                            '{:,.2f}'.format(
                                            report_data['kpi']['total_qty']
                                            )
                                        "
                                    />

                                </td>

                                <td
                                    colspan="2"
                                    style="
                                        border:1px solid #000;
                                        padding:6px;
                                    "
                                />

                                <td
                                    style="
                                        border:1px solid #000;
                                        padding:6px;
                                        text-align:right;
                                        font-weight:bold;
                                    "
                                >

                                    <t
                                        t-out="
                                            '{:,.2f}'.format(
                                            report_data['kpi']['stock_value']
                                            )
                                        "
                                    />

                                </td>

                            </tr>

                        </tfoot>

                    </table>

                    <!-- ===================================== -->
                    <!-- OBSERVATIONS -->
                    <!-- ===================================== -->

                    <t
                        t-if="
                            wizard.observations
                        "
                    >

                        <div
                            style="
                                margin-top:20px;
                                border:1px solid #000;
                                padding:10px;
                            "
                        >

                            <strong>

                                Observations

                            </strong>

                            <br/>
                            <br/>

                            <t
                                t-esc="
                                    wizard.observations
                                "
                            />

                        </div>

                    </t>

                    <!-- ===================================== -->
                    <!-- SIGNATURES -->
                    <!-- ===================================== -->

                    <table
                        style="
                            width:100%;
                            margin-top:40px;
                        "
                    >

                        <tr>

                            <td
                                style="
                                    width:50%;
                                    text-align:center;
                                "
                            >

                                Préparé par

                                <br/>
                                <br/>
                                <br/>
                                <br/>

                                ____________________

                            </td>

                            <td
                                style="
                                    width:50%;
                                    text-align:center;
                                "
                            >

                                Validé par

                                <br/>
                                <br/>
                                <br/>
                                <br/>

                                ____________________

                            </td>

                        </tr>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>