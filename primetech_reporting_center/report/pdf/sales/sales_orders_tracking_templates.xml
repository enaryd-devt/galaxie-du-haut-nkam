<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template
        id="sales_orders_tracking">

        <t t-call="web.html_container">

            <t t-call="web.external_layout">

                <div class="page">

                    <h2
                        style="
                            text-align:center;
                            margin-bottom:20px;
                        ">

                        SUIVI DES COMMANDES

                    </h2>

                    <table
                        class="table table-sm table-bordered">

                        <tr>

                            <td>
                                <strong>Date début</strong>
                            </td>

                            <td>
                                <t t-esc="wizard.date_from"/>
                            </td>

                            <td>
                                <strong>Date fin</strong>
                            </td>

                            <td>
                                <t t-esc="wizard.date_to"/>
                            </td>

                        </tr>

                        <tr>

                            <td>
                                <strong>Société</strong>
                            </td>

                            <td>
                                <t t-esc="wizard.company_id.name"/>
                            </td>

                            <td>
                                <strong>Commercial</strong>
                            </td>

                            <td>

                                <t t-esc="
                                    wizard.user_id.name
                                    if wizard.user_id
                                    else 'Tous'
                                "/>

                            </td>

                        </tr>

                    </table>

                    <h4>
                        Résumé Exécutif
                    </h4>

                    <table
                        class="table table-sm table-bordered">

                        <tr>

                            <th>Commandes</th>
                            <th>Clients</th>
                            <th>Qté</th>
                            <th>CA HT</th>
                            <th>CA TTC</th>
                            <th>Panier Moyen</th>

                        </tr>

                        <tr>

                            <td>
                                <t t-esc="report_data['summary']['order_count']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['customer_count']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['qty']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['turnover_ht']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['turnover_ttc']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['average_ticket']"/>
                            </td>

                        </tr>

                    </table>

                    <h4>
                        Top Commerciaux
                    </h4>

                    <table
                        class="table table-sm table-bordered">

                        <thead>

                            <tr>

                                <th>Commercial</th>
                                <th>Commandes</th>
                                <th>Quantité</th>
                                <th>CA TTC</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr
                                t-foreach="
                                    report_data['salesperson_ranking']
                                "
                                t-as="line">

                                <td>
                                    <t t-esc="line['salesperson']"/>
                                </td>

                                <td>
                                    <t t-esc="line['order_count']"/>
                                </td>

                                <td>
                                    <t t-esc="line['qty']"/>
                                </td>

                                <td>
                                    <t t-esc="line['amount']"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <h4>
                        Top Clients
                    </h4>

                    <table
                        class="table table-sm table-bordered">

                        <thead>

                            <tr>

                                <th>Client</th>
                                <th>Commandes</th>
                                <th>Montant TTC</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr
                                t-foreach="
                                    report_data['customer_ranking']
                                "
                                t-as="line">

                                <td>
                                    <t t-esc="line['customer']"/>
                                </td>

                                <td>
                                    <t t-esc="line['order_count']"/>
                                </td>

                                <td>
                                    <t t-esc="line['amount']"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <h4>
                        Top Produits
                    </h4>

                    <table
                        class="table table-sm table-bordered">

                        <thead>

                            <tr>

                                <th>Produit</th>
                                <th>Quantité</th>
                                <th>Montant</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr
                                t-foreach="
                                    report_data['product_ranking']
                                "
                                t-as="line">

                                <td>
                                    <t t-esc="line['product']"/>
                                </td>

                                <td>
                                    <t t-esc="line['qty']"/>
                                </td>

                                <td>
                                    <t t-esc="line['amount']"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <h4>
                        Alertes
                    </h4>

                    <table
                        class="table table-sm table-bordered">

                        <thead>

                            <tr>

                                <th>Commande</th>
                                <th>Client</th>
                                <th>Jours</th>
                                <th>Montant</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr
                                t-foreach="
                                    report_data['alerts']['delayed_orders']
                                "
                                t-as="alert">

                                <td>
                                    <t t-esc="alert['name']"/>
                                </td>

                                <td>
                                    <t t-esc="alert['customer']"/>
                                </td>

                                <td>
                                    <t t-esc="alert['days']"/>
                                </td>

                                <td>
                                    <t t-esc="alert['amount']"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <div
                        style="
                            page-break-before:always;
                        ">

                        <h4>
                            Détail des Commandes
                        </h4>

                        <table
                            class="table table-sm table-bordered">

                            <thead>

                                <tr>

                                    <th>Commande</th>
                                    <th>Date</th>
                                    <th>Client</th>
                                    <th>Commercial</th>
                                    <th>Etat</th>
                                    <th>Qté</th>
                                    <th>HT</th>
                                    <th>TTC</th>

                                </tr>

                            </thead>

                            <tbody>

                                <tr
                                    t-foreach="
                                        report_data['order_lines']
                                    "
                                    t-as="line">

                                    <td>
                                        <t t-esc="line['name']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['date']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['customer']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['salesperson']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['state']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['qty']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['amount_ht']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['amount_ttc']"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                    <br/>
                    <br/>
                    <br/>

                    <table
                        style="
                            width:100%;
                            margin-top:80px;
                        ">

                        <tr>

                            <td
                                style="
                                    text-align:center;
                                ">

                                Préparé par

                                <br/>
                                <br/>
                                <br/>

                                ____________________

                            </td>

                            <td
                                style="
                                    text-align:center;
                                ">

                                Vérifié par

                                <br/>
                                <br/>
                                <br/>

                                ____________________

                            </td>

                            <td
                                style="
                                    text-align:center;
                                ">

                                Approuvé par

                                <br/>
                                <br/>
                                <br/>

                                ____________________

                            </td>

                        </tr>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>