<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template
        id="invoice_analysis_pdf_template">

        <t t-call="web.html_container">

            <t t-call="web.external_layout">

                <div class="page">

                    <h2
                        style="
                            text-align:center;
                            margin-bottom:20px;
                        ">

                        ANALYSE DE FACTURATION

                    </h2>

                    <!-- FILTRES -->

                    <table class="table table-sm table-bordered">

                        <tr>

                            <td>
                                <strong>Date début</strong>
                            </td>

                            <td>
                                <t t-esc="wizard.date_from"/>
                            </td>

                            <td>
                                <strong>Date fin</strong>
                            </td>

                            <td>
                                <t t-esc="wizard.date_to"/>
                            </td>

                        </tr>

                        <tr>

                            <td>
                                <strong>Société</strong>
                            </td>

                            <td>
                                <t t-esc="wizard.company_id.name"/>
                            </td>

                            <td>
                                <strong>Commercial</strong>
                            </td>

                            <td>

                                <t t-esc="
                                    wizard.user_id.name
                                    if wizard.user_id
                                    else 'Tous'
                                "/>

                            </td>

                        </tr>

                    </table>

                    <!-- KPI -->

                    <h4>
                        Résumé Exécutif
                    </h4>

                    <table class="table table-sm table-bordered">

                        <tr>

                            <th>Factures</th>
                            <th>Clients</th>
                            <th>HT</th>
                            <th>TVA</th>
                            <th>TTC</th>
                            <th>Payé</th>
                            <th>Solde</th>

                        </tr>

                        <tr>

                            <td>
                                <t t-esc="report_data['summary']['invoice_count']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['customer_count']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['total_ht']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['total_tax']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['total_ttc']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['paid_amount']"/>
                            </td>

                            <td>
                                <t t-esc="report_data['summary']['residual_amount']"/>
                            </td>

                        </tr>

                    </table>

                    <!-- TOP CLIENTS -->

                    <h4>
                        Top Clients
                    </h4>

                    <table class="table table-sm table-bordered">

                        <thead>

                            <tr>

                                <th>Client</th>
                                <th>Factures</th>
                                <th>Montant</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr
                                t-foreach="report_data['customer_ranking']"
                                t-as="line">

                                <td>
                                    <t t-esc="line['customer']"/>
                                </td>

                                <td>
                                    <t t-esc="line['count']"/>
                                </td>

                                <td>
                                    <t t-esc="line['amount']"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <!-- TOP COMMERCIAUX -->

                    <h4>
                        Top Commerciaux
                    </h4>

                    <table class="table table-sm table-bordered">

                        <thead>

                            <tr>

                                <th>Commercial</th>
                                <th>Factures</th>
                                <th>CA TTC</th>

                            </tr>

                        </thead>

                        <tbody>

                            <tr
                                t-foreach="report_data['salesperson_ranking']"
                                t-as="line">

                                <td>
                                    <t t-esc="line['salesperson']"/>
                                </td>

                                <td>
                                    <t t-esc="line['count']"/>
                                </td>

                                <td>
                                    <t t-esc="line['amount']"/>
                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <!-- PAGE DETAIL -->

                    <div
                        style="
                            page-break-before:always;
                        ">

                        <h4>
                            Détail des Factures
                        </h4>

                        <table
                            class="table table-sm table-bordered">

                            <thead>

                                <tr>

                                    <th>Facture</th>
                                    <th>Date</th>
                                    <th>Client</th>
                                    <th>Commercial</th>
                                    <th>Etat</th>
                                    <th>TTC</th>
                                    <th>Solde</th>

                                </tr>

                            </thead>

                            <tbody>

                                <tr
                                    t-foreach="report_data['invoice_lines']"
                                    t-as="line">

                                    <td>
                                        <t t-esc="line['invoice']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['date']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['customer']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['salesperson']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['payment_state']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['ttc']"/>
                                    </td>

                                    <td>
                                        <t t-esc="line['residual']"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                    <!-- SIGNATURES -->

                    <table
                        style="
                            width:100%;
                            margin-top:80px;
                        ">

                        <tr>

                            <td
                                style="
                                    text-align:center;
                                ">

                                Préparé par

                                <br/><br/><br/>

                                ____________________

                            </td>

                            <td
                                style="
                                    text-align:center;
                                ">

                                Vérifié par

                                <br/><br/><br/>

                                ____________________

                            </td>

                            <td
                                style="
                                    text-align:center;
                                ">

                                Approuvé par

                                <br/><br/><br/>

                                ____________________

                            </td>

                        </tr>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>