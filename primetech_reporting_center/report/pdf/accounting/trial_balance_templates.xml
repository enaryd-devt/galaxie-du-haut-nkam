<?xml version="1.0" encoding="utf-8"?>

<odoo>

<template id="trial_balance_report_template">

    <t t-call="web.html_container">

        <t t-call="web.external_layout">

            <div class="page">

                <!-- ENTETE -->

                <table style="
                    width:100%;
                    font-size:12px;
                    color:#000000;
                ">

                    <tr>

                        <td style="width:60%;">

                            <strong>
                                <t t-esc="env.company.name"/>
                            </strong>

                        </td>

                        <td style="text-align:right;">

                            Date d'impression :
                            <t t-esc="generated_at"/>

                        </td>

                    </tr>

                </table>

                <br/>

                <h2 style="
                    text-align:center;
                    margin-bottom:5px;
                    color:#000000;
                ">
                    <strong>
                        BALANCE GENERALE DES COMPTES
                    </strong>
                </h2>

                <div style="
                    text-align:center;
                    font-size:12px;
                    margin-bottom:15px;
                    color:#000000;
                ">

                    Période du

                    <strong>
                        <t t-esc="date_from"/>
                    </strong>

                    au

                    <strong>
                        <t t-esc="date_to"/>
                    </strong>

                </div>

                <!-- TABLEAU -->

                <table
                    class="table table-sm"
                    style="
                        width:100%;
                        border-collapse:collapse;
                        font-size:11px;
                        color:#000000;
                    ">

                        <thead>

                            <!-- LIGNE 1 -->

                            <tr>

                                <th rowspan="3"
                                    style="
                                        border:0.4px solid #6b7280;
                                        background:#ffffff;
                                        color:#000000;
                                        text-align:center;
                                        vertical-align:middle;
                                        font-weight:700;
                                        padding:6px;
                                        width:9%;
                                    ">
                                    Compte
                                </th>

                                <th rowspan="3"
                                    style="
                                        border:0.4px solid #6b7280;
                                        background:#ffffff;
                                        color:#000000;
                                        text-align:center;
                                        vertical-align:middle;
                                        font-weight:700;
                                        padding:6px;
                                        width:28%;
                                    ">
                                    Intitulé des comptes
                                </th>

                                <th colspan="2"
                                    style="
                                        border:0.4px solid #6b7280;
                                        background:#ffffff;
                                        color:#000000;
                                        text-align:center;
                                        font-weight:700;
                                        padding:6px;
                                    ">
                                    Soldes Initiaux

                                    <br/>

                                    <span style="
                                        font-size:10px;
                                        font-weight:400;
                                    ">
                                        Exercice
                                        <t t-esc="previous_year"/>
                                    </span>

                                </th>

                                <th rowspan="2"
                                    colspan="2"
                                    style="
                                        border:0.4px solid #6b7280;
                                        background:#ffffff;
                                        color:#000000;
                                        text-align:center;
                                        vertical-align:middle;
                                        font-weight:700;
                                        padding:6px;
                                    ">
                                    Mouvements
                                </th>

                                <th rowspan="2"
                                    colspan="2"
                                    style="
                                        border:0.4px solid #6b7280;
                                        background:#ffffff;
                                        color:#000000;
                                        text-align:center;
                                        vertical-align:middle;
                                        font-weight:700;
                                        padding:6px;
                                    ">
                                    Soldes Cumulés
                                </th>

                            </tr>

                            <!-- LIGNE 2 -->

                            <tr>

                                <th colspan="2"
                                    style="
                                        border:0.4px solid #6b7280;
                                        background:#ffffff;
                                        color:#000000;
                                        text-align:center;
                                        font-weight:700;
                                        padding:4px;
                                    ">
                                    Situation d'ouverture
                                </th>

                            </tr>

                            <!-- LIGNE 3 -->

                            <tr>

                                <th style="
                                    border:0.4px solid #6b7280;
                                    background:#ffffff;
                                    color:#000000;
                                    text-align:center;
                                    font-weight:700;
                                    padding:4px;
                                ">
                                    Débit
                                </th>

                                <th style="
                                    border:0.4px solid #6b7280;
                                    background:#ffffff;
                                    color:#000000;
                                    text-align:center;
                                    font-weight:700;
                                    padding:4px;
                                ">
                                    Crédit
                                </th>

                                <th style="
                                    border:0.4px solid #6b7280;
                                    background:#ffffff;
                                    color:#000000;
                                    text-align:center;
                                    font-weight:700;
                                    padding:4px;
                                ">
                                    Débit
                                </th>

                                <th style="
                                    border:0.4px solid #6b7280;
                                    background:#ffffff;
                                    color:#000000;
                                    text-align:center;
                                    font-weight:700;
                                    padding:4px;
                                ">
                                    Crédit
                                </th>

                                <th style="
                                    border:0.4px solid #6b7280;
                                    background:#ffffff;
                                    color:#000000;
                                    text-align:center;
                                    font-weight:700;
                                    padding:4px;
                                ">
                                    Débit
                                </th>

                                <th style="
                                    border:0.4px solid #6b7280;
                                    background:#ffffff;
                                    color:#000000;
                                    text-align:center;
                                    font-weight:700;
                                    padding:4px;
                                ">
                                    Crédit
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                                <t t-foreach="data['lines']" t-as="line">

                                    <t t-if="
                                        line['opening_debit']
                                        or line['opening_credit']
                                        or line['period_debit']
                                        or line['period_credit']
                                        or line['closing_debit']
                                        or line['closing_credit']
                                    ">

                                        <tr t-att-style="

                                            'background:#ececec;font-weight:bold;color:#000000;'
                                            if line['level'] == 1 else

                                            'background:#f5f5f5;font-weight:bold;color:#000000;'
                                            if line['level'] == 2 else

                                            'background:#fafafa;font-weight:bold;color:#000000;'
                                            if line['level'] == 3 else

                                            'background:#ffffff;color:#000000;'

                                        ">

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                            ">

                                                <t t-esc="line['code']"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                            ">

                                                <t t-esc="line['name']"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                                text-align:right;
                                            ">

                                                <t t-esc="'{:,.0f}'.format(line['opening_debit'])"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                                text-align:right;
                                            ">

                                                <t t-esc="'{:,.0f}'.format(line['opening_credit'])"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                                text-align:right;
                                            ">

                                                <t t-esc="'{:,.0f}'.format(line['period_debit'])"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                                text-align:right;
                                            ">

                                                <t t-esc="'{:,.0f}'.format(line['period_credit'])"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                                text-align:right;
                                            ">

                                                <t t-esc="'{:,.0f}'.format(line['closing_debit'])"/>

                                            </td>

                                            <td style="
                                                border:0.4px solid #d1d5db;
                                                padding:4px;
                                                text-align:right;
                                            ">

                                                <t t-esc="'{:,.0f}'.format(line['closing_credit'])"/>

                                            </td>

                                        </tr>

                                    </t>

                                </t>

                                <!-- TOTAL BILAN -->

                                <tr style="
                                    background:#ededed;
                                    color:#000000;
                                    font-weight:bold;
                                    border-top:1px solid #9ca3af;
                                ">

                                    <td colspan="2"
                                        style="
                                            border:0.4px solid #9ca3af;
                                            padding:6px;
                                        ">
                                        TOTAL COMPTES DE BILAN
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_bilan']['opening_debit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_bilan']['opening_credit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_bilan']['period_debit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_bilan']['period_credit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_bilan']['closing_debit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_bilan']['closing_credit'])"/>
                                    </td>

                                </tr>

                                <!-- TOTAL GESTION -->

                                <tr style="
                                    background:#f5f5f5;
                                    color:#000000;
                                    font-weight:bold;
                                ">

                                    <td colspan="2"
                                        style="
                                            border:0.4px solid #9ca3af;
                                            padding:6px;
                                        ">
                                        TOTAL COMPTES DE GESTION
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_gestion']['opening_debit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_gestion']['opening_credit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_gestion']['period_debit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_gestion']['period_credit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_gestion']['closing_debit'])"/>
                                    </td>

                                    <td style="border:0.4px solid #9ca3af;padding:6px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_gestion']['closing_credit'])"/>
                                    </td>

                                </tr>

                                <!-- TOTAL BALANCE -->

                                <tr style="
                                    background:#e0e0e0;
                                    color:#000000;
                                    font-weight:bold;
                                    font-size:12px;
                                ">

                                    <td colspan="2"
                                        style="
                                            border:1px solid #808080;
                                            padding:8px;
                                        ">
                                        TOTAL BALANCE
                                    </td>

                                    <td style="border:1px solid #808080;padding:8px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_balance']['opening_debit'])"/>
                                    </td>

                                    <td style="border:1px solid #808080;padding:8px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_balance']['opening_credit'])"/>
                                    </td>

                                    <td style="border:1px solid #808080;padding:8px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_balance']['period_debit'])"/>
                                    </td>

                                    <td style="border:1px solid #808080;padding:8px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_balance']['period_credit'])"/>
                                    </td>

                                    <td style="border:1px solid #808080;padding:8px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_balance']['closing_debit'])"/>
                                    </td>

                                    <td style="border:1px solid #808080;padding:8px;text-align:right;">
                                        <t t-esc="'{:,.0f}'.format(data['totals_balance']['closing_credit'])"/>
                                    </td>

                                </tr>

                        </tbody>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>