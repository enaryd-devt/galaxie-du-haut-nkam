<?xml version="1.0" encoding="UTF-8"?>

<odoo>

<template id="partner_balance_template">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">
    
        

    <div style="
        font-family:Arial;
        font-size:12px;
        padding:20px;
        color:#000;
        ">

        <div style="
            text-align:center;
            margin-bottom:20px;
        ">

            <h2>
                BALANCE DES TIERS
            </h2>

            <div>

                Du

                <strong>
                    <t t-esc="date_from"/>
                </strong>

                au

                <strong>
                    <t t-esc="date_to"/>
                </strong>

            </div>

            <div>

                Généré le
                <t t-esc="generated_at"/>

            </div>

        </div>

        <table style="
            width:100%;
            border-collapse:collapse;
        ">

            <thead>

                <tr style="
                    background:#E6E6E6;
                ">

                    <th style="border:1px solid #999;padding:6px;">
                        Tiers
                    </th>

                    <th style="border:1px solid #999;padding:6px;">
                        SI Débit
                    </th>

                    <th style="border:1px solid #999;padding:6px;">
                        SI Crédit
                    </th>

                    <th style="border:1px solid #999;padding:6px;">
                        Mvt Débit
                    </th>

                    <th style="border:1px solid #999;padding:6px;">
                        Mvt Crédit
                    </th>

                    <th style="border:1px solid #999;padding:6px;">
                        SF Débit
                    </th>

                    <th style="border:1px solid #999;padding:6px;">
                        SF Crédit
                    </th>

                </tr>

            </thead>

            <tbody>

                <t t-foreach="data['partners']"
                t-as="partner">

                    <tr>

                        <td style="border:1px solid #ccc;padding:5px;">

                            <t t-esc="partner['partner_name']"/>

                        </td>

                        <td style="
                            border:1px solid #ccc;
                            padding:5px;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(partner['opening_debit'])"/>
                        </td>

                        <td style="
                            border:1px solid #ccc;
                            padding:5px;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(partner['opening_credit'])"/>
                        </td>

                        <td style="
                            border:1px solid #ccc;
                            padding:5px;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(partner['period_debit'])"/>
                        </td>

                        <td style="
                            border:1px solid #ccc;
                            padding:5px;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(partner['period_credit'])"/>
                        </td>

                        <td style="
                            border:1px solid #ccc;
                            padding:5px;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(partner['closing_debit'])"/>
                        </td>

                        <td style="
                            border:1px solid #ccc;
                            padding:5px;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(partner['closing_credit'])"/>
                        </td>

                    </tr>

                </t>

                <tr style="
                    background:#F5F5F5;
                    font-weight:bold;
                ">

                    <td style="border:1px solid #999;padding:6px;">
                        TOTAL
                    </td>

                    <td style="border:1px solid #999;padding:6px;text-align:right;">
                        <t t-esc="'{:,.0f}'.format(data['total_opening_debit'])"/>
                    </td>

                    <td style="border:1px solid #999;padding:6px;text-align:right;">
                        <t t-esc="'{:,.0f}'.format(data['total_opening_credit'])"/>
                    </td>

                    <td style="border:1px solid #999;padding:6px;text-align:right;">
                        <t t-esc="'{:,.0f}'.format(data['total_debit'])"/>
                    </td>

                    <td style="border:1px solid #999;padding:6px;text-align:right;">
                        <t t-esc="'{:,.0f}'.format(data['total_credit'])"/>
                    </td>

                    <td style="border:1px solid #999;padding:6px;text-align:right;">
                        <t t-esc="'{:,.0f}'.format(data['total_closing_debit'])"/>
                    </td>

                    <td style="border:1px solid #999;padding:6px;text-align:right;">
                        <t t-esc="'{:,.0f}'.format(data['total_closing_credit'])"/>
                    </td>

                </tr>

            </tbody>

        </table>

    </div>

    </t>
    </t>


</template>

</odoo>