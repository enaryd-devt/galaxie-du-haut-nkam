<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template id="vat_report_template">

    <t t-call="web.html_container">

    <div style="
        padding:20px;
        font-family:Arial;
    ">

        <div style="text-align:center;">

            <h2>
                RAPPORT TVA
            </h2>

            <div>

                Période :

                <strong>
                    <t t-esc="date_from"/>
                </strong>

                à

                <strong>
                    <t t-esc="date_to"/>
                </strong>

            </div>

        </div>

        <br/>

        <table style="
            width:100%;
            border-collapse:collapse;
        ">
                <thead>

                <tr style="
                    background:#D9EAD3;
                ">

                    <th style="
                        border:1px solid #999;
                        padding:8px;
                        text-align:left;
                    ">
                        Désignation
                    </th>

                    <th style="
                        border:1px solid #999;
                        padding:8px;
                        text-align:right;
                    ">
                        Montant
                    </th>

                </tr>

            </thead>

            <tbody>

                <tr>

                    <td style="
                        border:1px solid #CCC;
                        padding:8px;
                    ">
                        TVA Collectée
                    </td>

                    <td style="
                        border:1px solid #CCC;
                        padding:8px;
                        text-align:right;
                    ">
                        <t t-esc="'{:,.0f}'.format(data['tva_collectee'])"/>
                    </td>

                </tr>

                <tr>

                    <td style="
                        border:1px solid #CCC;
                        padding:8px;
                    ">
                        TVA Déductible
                    </td>

                    <td style="
                        border:1px solid #CCC;
                        padding:8px;
                        text-align:right;
                    ">
                        <t t-esc="'{:,.0f}'.format(data['tva_deductible'])"/>
                    </td>

                </tr>

                <tr style="
                    background:#EFEFEF;
                    font-weight:bold;
                ">

                    <td style="
                        border:1px solid #999;
                        padding:8px;
                    ">
                        TVA Nette
                    </td>

                    <td style="
                        border:1px solid #999;
                        padding:8px;
                        text-align:right;
                    ">
                        <t t-esc="'{:,.0f}'.format(data['tva_a_payer'])"/>
                    </td>

                </tr>

                <tr t-if="data['tva_a_payer'] &gt;= 0"
                    style="
                        background:#D9EAD3;
                        font-weight:bold;
                    ">

                    <td style="
                        border:1px solid #999;
                        padding:8px;
                    ">
                        TVA À PAYER
                    </td>

                    <td style="
                        border:1px solid #999;
                        padding:8px;
                        text-align:right;
                    ">
                        <t t-esc="'{:,.0f}'.format(data['tva_a_payer'])"/>
                    </td>

                </tr>

                <tr t-if="data['tva_a_payer'] &lt; 0"
                    style="
                        background:#F4CCCC;
                        font-weight:bold;
                    ">

                    <td style="
                        border:1px solid #999;
                        padding:8px;
                    ">
                        Crédit TVA à Reporter
                    </td>

                    <td style="
                        border:1px solid #999;
                        padding:8px;
                        text-align:right;
                    ">
                        <t t-esc="'{:,.0f}'.format(abs(data['tva_a_payer']))"/>
                    </td>

                </tr>

            </tbody>

        </table>

        <br/>

        <div style="
            font-size:11px;
            color:#666;
        ">

            Généré le
            <t t-esc="generated_at"/>

        </div>

    </div>

    </t>

    </template>

</odoo>