                            <t t-esc="'{:,.0f}'.format(line['net'])"/>
                        </td>

                        <td style="border:1px solid #999;"/>

                    </tr>

                </t>

                <!-- GRAND TOTAL -->

                <t t-if="line['line_type'] == 'grand_total'">

                    <tr style="
                        background:#D9D9D9;
                        font-weight:bold;
                    ">

                        <td style="border:1px solid #666;">
                            <t t-esc="line['ref']"/>
                        </td>

                        <td style="border:1px solid #666;">
                            <t t-esc="line['label']"/>
                        </td>

                        <td style="border:1px solid #666;"/>

                        <td style="
                            border:1px solid #666;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(line['brut'])"/>
                        </td>

                        <td style="border:1px solid #666;"/>

                        <td style="
                            border:1px solid #666;
                            text-align:right;
                        ">
                            <t t-esc="'{:,.0f}'.format(line['net'])"/>
                        </td>

                        <td style="border:1px solid #666;"/>

                    </tr>

                </t>

            </t>

        </tbody>

    </table>

</t>

</div>

</t>
</t>

</template>

</odoo>