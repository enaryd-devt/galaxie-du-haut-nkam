<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <template id="purchase_receipt_pdf">

        <t t-call="web.html_container">

            <t t-call="web.external_layout">

                <div class="page">

                    <!-- ===================================== -->
                    <!-- EN-TÊTE -->
                    <!-- ===================================== -->

                    <div class="text-center mb-4">

                        <h2>
                            Rapport des Réceptions
                        </h2>

                        <p>

                            <strong>Période :</strong>

                            <span
                                t-out="
                                    filters.get(
                                        'date_from'
                                    )
                                "
                            />

                            -

                            <span
                                t-out="
                                    filters.get(
                                        'date_to'
                                    )
                                "
                            />

                        </p>

                    </div>

                    <!-- ===================================== -->
                    <!-- KPI -->
                    <!-- ===================================== -->

                    <h3>
                        Indicateurs Clés
                    </h3>

                    <table
                        class="
                            table
                            table-sm
                            table-bordered
                        "
                    >

                        <tbody>

                            <tr>

                                <td>
                                    Réceptions
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'receipt_count',
                                                0
                                            )
                                        "
                                    />

                                </td>

                                <td>
                                    Fournisseurs
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'supplier_count',
                                                0
                                            )
                                        "
                                    />

                                </td>

                            </tr>

                            <tr>

                                <td>
                                    Produits
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'product_count',
                                                0
                                            )
                                        "
                                    />

                                </td>

                                <td>
                                    Terminées
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'done_count',
                                                0
                                            )
                                        "
                                    />

                                </td>

                            </tr>

                            <tr>

                                <td>
                                    En attente
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'waiting_count',
                                                0
                                            )
                                        "
                                    />

                                </td>

                                <td>
                                    Annulées
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'cancel_count',
                                                0
                                            )
                                        "
                                    />

                                </td>

                            </tr>

                            <tr>

                                <td>
                                    Qté Prévue
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'total_expected_qty',
                                                0
                                            )
                                        "
                                    />

                                </td>

                                <td>
                                    Qté Reçue
                                </td>

                                <td>

                                    <t
                                        t-out="
                                            report_data.get(
                                                'kpi',
                                                {}
                                            ).get(
                                                'total_received_qty',
                                                0
                                            )
                                        "
                                    />

                                </td>

                            </tr>

                        </tbody>

                    </table>

                    <!-- ===================================== -->
                    <!-- ANALYSE FOURNISSEURS -->
                    <!-- ===================================== -->

                    <h3>
                        Analyse Fournisseurs
                    </h3>

                    <table
                        class="
                            table
                            table-sm
                            table-bordered
                        "
                    >

                        <thead>

                            <tr>

                                <th>
                                    Fournisseur
                                </th>

                                <th>
                                    Réceptions
                                </th>

                                <th>
                                    Quantité
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <t
                                t-foreach="
                                    report_data.get(
                                        'supplier_analysis',
                                        {}
                                    ).items()
                                "
                                t-as="supplier"
                            >

                                <tr>

                                    <td>
                                        <t t-out="supplier[0]"/>
                                    </td>

                                    <td>
                                        <t
                                            t-out="
                                                supplier[1]['count']
                                            "
                                        />
                                    </td>

                                    <td>
                                        <t
                                            t-out="
                                                supplier[1]['qty']
                                            "
                                        />
                                    </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                    <!-- ===================================== -->
                    <!-- ANALYSE PRODUITS -->
                    <!-- ===================================== -->

                    <h3>
                        Analyse Produits
                    </h3>

                    <table
                        class="
                            table
                            table-sm
                            table-bordered
                        "
                    >

                        <thead>

                            <tr>

                                <th>
                                    Produit
                                </th>

                                <th>
                                    Quantité
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <t
                                t-foreach="
                                    report_data.get(
                                        'product_analysis',
                                        {}
                                    ).items()
                                "
                                t-as="product"
                            >

                                <tr>

                                    <td>
                                        <t t-out="product[0]"/>
                                    </td>

                                    <td>
                                        <t t-out="product[1]"/>
                                    </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                    <!-- ===================================== -->
                    <!-- DÉTAILS -->
                    <!-- ===================================== -->

                    <h3>
                        Détail des Réceptions
                    </h3>

                    <table
                        class="
                            table
                            table-sm
                            table-bordered
                        "
                    >

                        <thead>

                            <tr>

                                <th>
                                    Référence
                                </th>

                                <th>
                                    Date
                                </th>

                                <th>
                                    Fournisseur
                                </th>

                                <th>
                                    Origine
                                </th>

                                <th>
                                    Produit
                                </th>

                                <th>
                                    Qté Prévue
                                </th>

                                <th>
                                    Qté Reçue
                                </th>

                                <th>
                                    Statut
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <t
                                t-foreach="
                                    report_data.get(
                                        'details',
                                        []
                                    )
                                "
                                t-as="line"
                            >

                                <tr>

                                    <td>
                                        <t t-out="line['reference']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['date']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['supplier']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['origin']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['product']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['qty_expected']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['qty_received']"/>
                                    </td>

                                    <td>
                                        <t t-out="line['state']"/>
                                    </td>

                                </tr>

                            </t>

                        </tbody>

                    </table>

                    <!-- ===================================== -->
                    <!-- SIGNATURES -->
                    <!-- ===================================== -->

                    <br/>
                    <br/>
                    <br/>

                    <table style="width:100%;">

                        <tr>

                            <td
                                style="
                                    width:33%;
                                    text-align:center;
                                "
                            >

                                Préparé par

                                <br/>
                                <br/>
                                <br/>

                                __________________

                            </td>

                            <td
                                style="
                                    width:33%;
                                    text-align:center;
                                "
                            >

                                Vérifié par

                                <br/>
                                <br/>
                                <br/>

                                __________________

                            </td>

                            <td
                                style="
                                    width:33%;
                                    text-align:center;
                                "
                            >

                                Approuvé par

                                <br/>
                                <br/>
                                <br/>

                                __________________

                            </td>

                        </tr>

                    </table>

                </div>

            </t>

        </t>

    </template>

</odoo>