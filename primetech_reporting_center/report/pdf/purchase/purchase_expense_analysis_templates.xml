<?xml version="1.0" encoding="utf-8"?>

<odoo>

<template
    id="purchase_expense_pdf"
>

<t t-call="web.html_container">

<t t-call="web.external_layout">

<div class="page">

    <div
        style="
            text-align:center;
            margin-bottom:20px;
        "
    >

        <h2>

            ANALYSE DES DEPENSES

        </h2>

        <p>

            Du

            <strong>
                <t t-esc="filters.get('date_from')"/>
            </strong>

            au

            <strong>
                <t t-esc="filters.get('date_to')"/>
            </strong>

        </p>

    </div>

    <!-- KPI -->

    <table
        style="
            width:100%;
            border-collapse:collapse;
            margin-bottom:20px;
        "
    >

        <tr>

            <td
                style="
                    border:1px solid #DDD;
                    padding:10px;
                    text-align:center;
                "
            >

                <strong>Total HT</strong>

                <br/>

                <t t-esc="round(data['total_ht'],2)"/>

            </td>

            <td
                style="
                    border:1px solid #DDD;
                    padding:10px;
                    text-align:center;
                "
            >

                <strong>Total TTC</strong>

                <br/>

                <t t-esc="round(data['total_ttc'],2)"/>

            </td>

            <td
                style="
                    border:1px solid #DDD;
                    padding:10px;
                    text-align:center;
                "
            >

                <strong>Catégories</strong>

                <br/>

                <t t-esc="data['category_count']"/>

            </td>

            <td
                style="
                    border:1px solid #DDD;
                    padding:10px;
                    text-align:center;
                "
            >

                <strong>Fournisseurs</strong>

                <br/>

                <t t-esc="data['supplier_count']"/>

            </td>

        </tr>

    </table>

    <h4>

        Dépenses par Catégorie

    </h4>

    <table
        class="table table-sm table-bordered"
        style="margin-bottom:20px;"
    >

        <thead>

            <tr>

                <th>Catégorie</th>
                <th>Produits</th>
                <th>Montant HT</th>
                <th>% Budget</th>

            </tr>

        </thead>

        <tbody>

            <tr
                t-foreach="data['categories']"
                t-as="cat"
            >

                <td>
                    <t t-esc="cat['category']"/>
                </td>

                <td>
                    <t t-esc="cat['product_count']"/>
                </td>

                <td>
                    <t t-esc="round(cat['amount'],2)"/>
                </td>

                <td>
                    <t t-esc="round(cat['percent'],2)"/>%
                </td>

            </tr>

        </tbody>

    </table>
        <!-- ===================================== -->
    <!-- DEPENSES PAR FOURNISSEUR -->
    <!-- ===================================== -->

    <h4>

        Dépenses par Fournisseur

    </h4>

    <table
        class="table table-sm table-bordered"
        style="margin-bottom:20px;"
    >

        <thead>

            <tr>

                <th>Fournisseur</th>
                <th>Nb Cmdes</th>
                <th>Montant HT</th>
                <th>Montant TTC</th>

            </tr>

        </thead>

        <tbody>

            <tr
                t-foreach="data['suppliers']"
                t-as="supplier"
            >

                <td>
                    <t t-esc="supplier['supplier']"/>
                </td>

                <td>
                    <t t-esc="supplier['purchase_count']"/>
                </td>

                <td>
                    <t t-esc="round(supplier['amount_ht'],2)"/>
                </td>

                <td>
                    <t t-esc="round(supplier['amount_ttc'],2)"/>
                </td>

            </tr>

        </tbody>

    </table>

    <!-- ===================================== -->
    <!-- EVOLUTION MENSUELLE -->
    <!-- ===================================== -->

    <h4>

        Evolution Mensuelle

    </h4>

    <table
        class="table table-sm table-bordered"
        style="margin-bottom:20px;"
    >

        <thead>

            <tr>

                <th>Période</th>
                <th>Montant TTC</th>

            </tr>

        </thead>

        <tbody>

            <tr
                t-foreach="data['monthly']"
                t-as="month"
            >

                <td>
                    <t t-esc="month['period']"/>
                </td>

                <td>
                    <t t-esc="round(month['amount'],2)"/>
                </td>

            </tr>

        </tbody>

    </table>

    <!-- ===================================== -->
    <!-- DETAILS DES DEPENSES -->
    <!-- ===================================== -->

    <h4>

        Détail des Dépenses

    </h4>

    <table
        class="table table-sm table-bordered"
        style="
            width:100%;
            font-size:9px;
        "
    >

        <thead>

            <tr>

                <th>Date</th>
                <th>Fournisseur</th>
                <th>Catégorie</th>
                <th>Produit</th>
                <th>Qté</th>
                <th>Montant HT</th>

            </tr>

        </thead>

        <tbody>

            <tr
                t-foreach="data['lines']"
                t-as="line"
            >

                <td>
                    <t t-esc="line['date']"/>
                </td>

                <td>
                    <t t-esc="line['supplier']"/>
                </td>

                <td>
                    <t t-esc="line['category']"/>
                </td>

                <td>
                    <t t-esc="line['product']"/>
                </td>

                <td>
                    <t t-esc="line['qty']"/>
                </td>

                <td>
                    <t t-esc="round(line['amount'],2)"/>
                </td>

            </tr>

        </tbody>

        <tfoot>

            <tr
                style="
                    font-weight:bold;
                    background:#EFEFEF;
                "
            >

                <td colspan="5">

                    TOTAL GENERAL HT

                </td>

                <td>

                    <t t-esc="round(data['total_ht'],2)"/>

                </td>

            </tr>

        </tfoot>

    </table>
    <!-- ===================================== -->
<!-- SIGNATURES -->
<!-- ===================================== -->

<div
    style="
        margin-top:60px;
        width:100%;
    "
>

    <table
        style="
            width:100%;
            border:none;
        "
    >

        <tr>

            <td
                style="
                    width:50%;
                    text-align:center;
                    vertical-align:top;
                "
            >

                <strong>
                    Préparé par
                </strong>

                <br/>
                <br/>
                <br/>
                <br/>
                <br/>

                __________________________

            </td>

            <td
                style="
                    width:50%;
                    text-align:center;
                    vertical-align:top;
                "
            >

                <strong>
                    Validé par
                </strong>

                <br/>
                <br/>
                <br/>
                <br/>
                <br/>

                __________________________

            </td>

        </tr>

    </table>

</div>

</div>

</t>

</t>

</template>

</odoo>