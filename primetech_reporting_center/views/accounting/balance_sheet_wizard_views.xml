<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_balance_sheet_wizard"
            model="ir.ui.view">

        <field name="name">balance.sheet.wizard.form</field>

        <field name="model">primetech.balance.sheet.wizard</field>

        <field name="arch"
               type="xml">

            <form string="Bilan OHADA">

                <sheet>

                    <!-- ===================================== -->
                    <!-- TITRE -->
                    <!-- ===================================== -->

                    <div class="oe_title">

                        <h1>

                            Bilan OHADA

                        </h1>

                        <div class="text-muted">

                            Analyse de la situation patrimoniale
                            et financière de l'entreprise

                        </div>

                    </div>

                    <!-- ===================================== -->
                    <!-- INFORMATION -->
                    <!-- ===================================== -->

                    <div class="alert alert-warning"
                         role="alert">

                        <i class="fa fa-university me-2"/>

                        Générez le bilan comptable selon les normes OHADA
                        afin d'analyser les actifs, passifs et capitaux propres.

                    </div>

                    <!-- ===================================== -->
                    <!-- PARAMÈTRES -->
                    <!-- ===================================== -->

                    <group>

                        <group string="Période d'Analyse">

                            <field
                                name="date_from"
                                required="1"/>

                            <field
                                name="date_to"
                                required="1"/>

                        </group>

                        <group string="Options d'Affichage">

                            <field
                                name="posted_only"/>

                            <field
                                name="display_mode"/>

                        </group>

                    </group>

                    <!-- ===================================== -->
                    <!-- AIDE -->
                    <!-- ===================================== -->

                    <separator string="Contenu du Rapport"/>

                    <div class="text-muted">

                        Le bilan présentera :

                        <ul style="margin-top:8px;">

                            <li>
                                Les actifs immobilisés
                            </li>

                            <li>
                                Les actifs circulants
                            </li>

                            <li>
                                Les capitaux propres
                            </li>

                            <li>
                                Les dettes à court et long terme
                            </li>

                            <li>
                                Les totaux Actif et Passif
                            </li>

                            <li>
                                Les soldes comptables de la période
                            </li>

                        </ul>

                    </div>

                </sheet>

                <footer>

                    <button
                        name="action_open_report"
                        type="object"
                        string="Prévisualiser"
                        icon="fa-eye"
                        class="btn-primary"/>

                    <button
                        name="action_export_excel"
                        type="object"
                        string="Exporter Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

                    <button
                        string="Fermer"
                        special="cancel"
                        icon="fa-times"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>
