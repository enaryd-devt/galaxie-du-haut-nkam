<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record
        id="view_income_statement_wizard"
        model="ir.ui.view">

        <field name="name">income.statement.wizard.form</field>

        <field name="model">primetech.income.statement.wizard</field>

        <field name="arch" type="xml">

            <form string="Compte de Résultat">

                <sheet>

                    <!-- ===================================== -->
                    <!-- TITRE -->
                    <!-- ===================================== -->

                    <div class="oe_title">

                        <h1>

                            Compte de Résultat

                        </h1>

                        <div class="text-muted">

                            Analyse des produits, charges et résultat
                            de l'exercice selon les normes OHADA

                        </div>

                    </div>

                    <!-- ===================================== -->
                    <!-- INFORMATION -->
                    <!-- ===================================== -->

                    <div class="alert alert-success"
                         role="alert">

                        <i class="fa fa-line-chart me-2"/>

                        Générez une analyse détaillée de la performance
                        financière de votre entreprise sur la période sélectionnée.

                    </div>

                    <!-- ===================================== -->
                    <!-- PARAMÈTRES -->
                    <!-- ===================================== -->

                    <group>

                        <group string="Période d'Analyse">

                            <field
                                name="date_from"
                                required="1"/>

                            <field
                                name="date_to"
                                required="1"/>

                        </group>

                        <group string="Options">

                            <field
                                name="posted_only"/>

                        </group>

                    </group>

                    <!-- ===================================== -->
                    <!-- INFORMATIONS RAPPORT -->
                    <!-- ===================================== -->

                    <separator string="Indicateurs Analysés"/>

                    <div class="text-muted">

                        Ce rapport présente :

                        <ul style="margin-top:8px;">

                            <li>
                                Le chiffre d'affaires
                            </li>

                            <li>
                                Les produits d'exploitation
                            </li>

                            <li>
                                Les charges d'exploitation
                            </li>

                            <li>
                                Le résultat d'exploitation
                            </li>

                            <li>
                                Le résultat net de la période
                            </li>

                        </ul>

                    </div>

                </sheet>

                <footer>

                    <button
                        name="action_open_report"
                        type="object"
                        string="Prévisualiser"
                        icon="fa-eye"
                        class="btn-primary"/>

                    <button
                        name="action_print"
                        type="object"
                        string="Imprimer PDF"
                        icon="fa-print"
                        class="btn-info"/>

                    <button
                        name="action_export_excel"
                        type="object"
                        string="Exporter Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

                    <button
                        string="Fermer"
                        special="cancel"
                        icon="fa-times"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>
