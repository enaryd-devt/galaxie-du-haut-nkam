<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record
        id="view_accounting_journal_wizard"
        model="ir.ui.view">

        <field name="name">accounting.journal.wizard.form</field>

        <field name="model">primetech.accounting.journal.wizard</field>

        <field name="arch" type="xml">

            <form string="Journaux Comptables">

                <sheet>

                    <div class="oe_title">

                        <h1>
                            Journaux Comptables
                        </h1>

                        <div class="text-muted">
                            Analyse détaillée des mouvements comptables
                        </div>

                    </div>

                    <group>

                        <group string="Période">

                            <field name="date_from"/>

                            <field name="date_to"/>

                        </group>

                        <group string="Options">

                            <field name="posted_only"/>

                        </group>

                    </group>

                    <separator string="Journaux à Analyser"/>

                    <group>

                        <field
                            name="journal_ids"
                            widget="many2many_tags"
                            options="{'no_create': True}"/>

                    </group>

                </sheet>

                <footer>

                    <button
                        name="action_open_report"
                        type="object"
                        string="Prévisualiser"
                        icon="fa-eye"
                        class="btn-primary"/>

                    <button
                        name="action_export_excel"
                        type="object"
                        string="Exporter Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

                    <button
                        string="Fermer"
                        special="cancel"
                        icon="fa-times"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>
