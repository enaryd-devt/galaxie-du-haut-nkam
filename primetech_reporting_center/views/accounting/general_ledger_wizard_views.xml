<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record
        id="view_general_ledger_wizard"
        model="ir.ui.view">

        <field name="name">primetech.general.ledger.wizard.form</field>

        <field name="model">primetech.general.ledger.wizard</field>

        <field name="arch" type="xml">

            <form string="Grand Livre OHADA">

                <sheet>

                    <!-- ===================================== -->
                    <!-- TITRE -->
                    <!-- ===================================== -->

                    <div class="oe_title">

                        <h1>

                            Grand Livre OHADA

                        </h1>

                        <div class="text-muted">

                            Consultation détaillée des mouvements
                            comptables par compte

                        </div>

                    </div>

                    <!-- ===================================== -->
                    <!-- INFORMATION -->
                    <!-- ===================================== -->

                    <div class="alert alert-primary"
                         role="alert">

                        <i class="fa fa-book me-2"/>

                        Définissez la période et la plage de comptes
                        à analyser pour générer le Grand Livre.

                    </div>

                    <!-- ===================================== -->
                    <!-- PARAMETRES -->
                    <!-- ===================================== -->

                    <group>

                        <group string="Période d'Analyse">

                            <field
                                name="date_from"/>

                            <field
                                name="date_to"/>

                        </group>

                        <group string="Options">

                            <field
                                name="posted_only"/>

                            <field
                                name="hide_zero_balance"/>

                        </group>

                    </group>

                    <!-- ===================================== -->
                    <!-- COMPTES -->
                    <!-- ===================================== -->

                    <separator string="Plage de Comptes"/>

                    <group>

                        <group>

                            <field
                                name="account_from_id"
                                options="{'no_create': True,
                                          'no_open': True}"/>

                        </group>

                        <group>

                            <field
                                name="account_to_id"
                                options="{'no_create': True,
                                          'no_open': True}"/>

                        </group>

                    </group>

                    <!-- ===================================== -->
                    <!-- AIDE -->
                    <!-- ===================================== -->

                    <separator string="Contenu du Rapport"/>

                    <div class="text-muted">

                        Le Grand Livre présentera :

                        <ul style="margin-top:8px;">

                            <li>
                                Les écritures détaillées par compte
                            </li>

                            <li>
                                Les soldes initiaux
                            </li>

                            <li>
                                Les mouvements débiteurs et créditeurs
                            </li>

                            <li>
                                Les soldes cumulés
                            </li>

                            <li>
                                Les totaux par compte
                            </li>

                        </ul>

                    </div>

                </sheet>

                <footer>

                    <button
                        name="action_open_report"
                        type="object"
                        string="Prévisualiser"
                        icon="fa-eye"
                        class="btn-primary"/>

                    <button
                        name="action_export_excel"
                        type="object"
                        string="Exporter Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

                    <button
                        string="Fermer"
                        special="cancel"
                        icon="fa-times"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>
