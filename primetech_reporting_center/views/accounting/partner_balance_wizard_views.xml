<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record
        id="view_partner_balance_wizard"
        model="ir.ui.view">

        <field name="name">partner.balance.wizard.form</field>

        <field name="model">primetech.partner.balance.wizard</field>

        <field name="arch"
               type="xml">

            <form string="Balance des Tiers">

                <sheet>

                    <div class="oe_title">

                        <h1>
                            Balance des Tiers
                        </h1>

                        <div class="text-muted">
                            Analyse des soldes clients et fournisseurs
                            sur une période donnée
                        </div>

                    </div>

                    <group>

                        <group string="Période">

                            <field name="date_from"/>

                            <field name="date_to"/>

                        </group>

                        <group string="Paramètres">

                            <field
                                name="partner_type"
                                widget="radio"/>

                            <field
                                name="posted_only"/>

                        </group>

                    </group>

                    <separator string="Analyse"/>

                    <div class="text-muted">

                        Ce rapport permet de consulter :

                        <ul style="margin-top:8px;">
                            <li>Les soldes clients</li>
                            <li>Les soldes fournisseurs</li>
                            <li>Les mouvements débiteurs et créditeurs</li>
                            <li>Les balances ouvertes et clôturées</li>
                        </ul>

                    </div>

                </sheet>

                <footer>

                    <button
                        name="action_open_report"
                        type="object"
                        string="Prévisualiser"
                        icon="fa-eye"
                        class="btn-primary"/>

                    <button
                        name="action_export_excel"
                        type="object"
                        string="Exporter Excel"
                        icon="fa-file-excel-o"
                        class="btn-success"/>

                    <button
                        string="Fermer"
                        special="cancel"
                        icon="fa-times"
                        class="btn-secondary"/>

                </footer>

            </form>

        </field>

    </record>

</odoo>
