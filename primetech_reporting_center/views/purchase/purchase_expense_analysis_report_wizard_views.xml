<?xml version="1.0" encoding="utf-8"?>

<odoo>


<record
    id="view_purchase_expense_wizard"
    model="ir.ui.view"
>

    <field name="name">purchase.expense.wizard.form</field>
    <field name="model">primetech.purchase.expense.wizard</field>

    <field name="arch" type="xml">

        <form
            string="Analyse des Dépenses"
            create="false"
            edit="false"
        >

            <sheet>

                <!-- ===================================== -->
                <!-- HERO HEADER -->
                <!-- ===================================== -->

                <div
                    class="d-flex align-items-center mb-4 p-4 rounded"
                    style="
                        background:linear-gradient(
                            135deg,
                            #FFF7ED 0%,
                            #FFEDD5 100%
                        );
                        border:1px solid #FED7AA;
                    "
                >

                    <div
                        class="rounded-circle d-flex align-items-center justify-content-center me-4"
                        style="
                            width:72px;
                            height:72px;
                            background:#EA580C;
                            color:white;
                            font-size:28px;
                            flex-shrink:0;
                        "
                    >

                        <i
                            class="fa fa-line-chart"
                            title="Analyse des Dépenses"
                        />

                    </div>

                    <div>

                        <h1
                            class="mb-2"
                            style="
                                color:#9A3412;
                                font-weight:700;
                            "
                        >
                            Analyse des Dépenses
                        </h1>

                        <div
                            class="text-muted"
                            style="
                                font-size:15px;
                            "
                        >

                            Analyse approfondie des dépenses
                            d'achat par fournisseur,
                            catégorie et produit avec suivi
                            de l'évolution des coûts.

                        </div>

                    </div>

                </div>

                <!-- ===================================== -->
                <!-- DESCRIPTION -->
                <!-- ===================================== -->

                <div
                    class="alert alert-warning mb-4"
                >

                    <strong>
                        Indicateurs disponibles :
                    </strong>

                    <br/>

                    • Dépenses par catégorie

                    <br/>

                    • Dépenses par fournisseur

                    <br/>

                    • Evolution mensuelle

                    <br/>

                    • Catégories les plus coûteuses

                    <br/>

                    • Fournisseurs stratégiques

                    <br/>

                    • Détail complet des lignes d'achat

                </div>

                <!-- ===================================== -->
                <!-- FILTRES -->
                <!-- ===================================== -->

                <group
                    string="Critères d'analyse"
                >

                    <group>

                        <field
                            name="date_from"
                        />

                        <field
                            name="date_to"
                        />

                    </group>

                    <group>

                        <field
                            name="company_id"
                        />

                        <field
                            name="state"
                        />

                    </group>

                </group>

                <group
                    string="Fournisseurs"
                >

                    <field
                        name="supplier_ids"
                        widget="many2many_tags"
                        options="{'color_field': false}"
                    />

                </group>

            </sheet>

            <!-- ===================================== -->
            <!-- ACTIONS -->
            <!-- ===================================== -->

            <footer>

                <button
                    name="action_preview"
                    type="object"
                    string="Aperçu"
                    icon="fa-eye"
                    class="btn btn-primary"
                />

                <button
                    name="action_print_pdf"
                    type="object"
                    string="PDF"
                    icon="fa-file-pdf-o"
                    class="btn btn-secondary"
                />

                <button
                    name="action_export_xlsx"
                    type="object"
                    string="Excel"
                    icon="fa-file-excel-o"
                    class="btn btn-success"
                />

                <button
                    name="action_back"
                    type="object"
                    string="Retour"
                    class="btn btn-light"
                />

            </footer>

        </form>

    </field>

</record>


</odoo>
