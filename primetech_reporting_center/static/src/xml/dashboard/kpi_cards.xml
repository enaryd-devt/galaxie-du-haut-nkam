<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

<t t-name="primetech_reporting_center.KPICards"
   owl="1">

    <div class="pt-kpi-grid">

        <!-- ===================================== -->
        <!-- CA -->
        <!-- ===================================== -->

        <div
            class="pt-kpi-card revenue pt-clickable"
            t-on-click="openRevenue">

            <div class="pt-kpi-icon">

                <i class="fa fa-line-chart"/>

            </div>

            <div class="pt-kpi-content">

                <div class="pt-kpi-title">
                    Chiffre d'Affaires
                </div>

                <div
                    class="pt-kpi-value"
                    t-att-style="
                        'font-size:' +
                        getFontSize(
                            formatCurrency(
                                state.revenue
                            )
                        )
                    ">

                    <t t-esc="
                        formatCurrency(
                            state.revenue
                        )
                    "/>

                </div>

                <div
                    t-att-class="
                        'pt-trend-pill ' +
                        getTrendClass(
                            state.revenue_trend
                        )
                    ">

                    <!-- Hausse -->

                    <i
                        t-if="state.revenue_trend &gt; 0"
                        class="fa fa-arrow-up"/>

                    <!-- Baisse -->

                    <i
                        t-if="state.revenue_trend &lt; 0"
                        class="fa fa-arrow-down"/>

                    <!-- Stable -->

                    <i
                        t-if="state.revenue_trend == 0"
                        class="fa fa-circle"/>

                    <span>

                        <t t-if="state.revenue_trend == 0">
                            Stable
                        </t>

                        <t t-if="state.revenue_trend != 0">

                            <t t-esc="
                                formatTrend(
                                    state.revenue_trend
                                )
                            "/>

                        </t>

                    </span>

                </div>

                <small class="pt-kpi-subtitle">
                    vs mois précédent
                </small>

            </div>

        </div>

