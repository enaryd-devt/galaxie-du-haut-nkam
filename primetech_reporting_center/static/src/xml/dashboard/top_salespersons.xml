<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

<t t-name="primetech_reporting_center.TopSalespersons"
   owl="1">

    <div class="pt-card pt-salespersons-card">

        <div class="pt-card-header pt-card-header-compact">

            <h3>

                Meilleurs commerciaux

            </h3>

        </div>

        <div class="pt-scroll-card pt-scroll-card-compact">

            <t t-if="state.loading">

                    <div class="pt-loader-container">

                        <div class="pt-loader"/>

                    </div>

                </t>

                <t t-else="">

                <table class="pt-risk-table pt-table-compact">

                    <thead>

                        <tr>

                            <th>
                                Commercial
                            </th>

                            <th class="text-end">
                                C.A
                            </th>

                            <th class="text-center">
                                Cmd
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr
                            t-foreach="state.salespersons"
                            t-as="person"
                            t-key="person.id"
                            class="pt-clickable-row"
                            t-on-click="
                                () => this.openSalesperson(
                                    person.id
                                )">

                            <td>

                                <t t-esc="person.name"/>

                            </td>

                            <td class="text-end">

                                <strong>

                                    <t t-esc="
                                        formatCurrency(
                                            person.amount
                                        )
                                    "/>

                                </strong>

                            </td>

                            <td class="text-center">

                                <span class="pt-badge">

                                    <t t-esc="
                                        person.orders
                                    "/>

                                </span>

                            </td>

                        </tr>

                        <tr
                            t-if="
                                !state.salespersons.length
                            ">

                            <td
                                colspan="3"
                                class="text-center">

                                Aucun commercial

                            </td>

                        </tr>

                    </tbody>

                </table>

            </t>

        </div>

    </div>

</t>

</templates>