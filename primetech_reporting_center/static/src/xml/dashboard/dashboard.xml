<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t
        t-name="primetech_reporting_center.Dashboard"
        owl="1">

        <div class="pt-reporting-dashboard">

            <!-- HEADER -->

            <div class="pt-dashboard-header">

                <div>

                    <h1>
                        Reporting Center
                    </h1>

                    <p>
                        Centre de pilotage décisionnel
                    </p>

                </div>

                <div class="pt-last-refresh">

                    <i class="fa fa-clock-o"/>

                    Dernière mise à jour :

                    <strong>

                        <t t-esc="
                            state.lastRefresh
                        "/>

                    </strong>

                </div>

            </div>

            <!-- CONTENU PLEINE LARGEUR -->

            <div class="pt-dashboard-layout">

                <div class="pt-dashboard-content">

                    <GlobalFilters
                        filters="state.filters"
                        onFiltersChanged.bind="updateFilters"/>

                    <PrimetechKPICards
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <ChartContainer
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <Champions
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <TargetsProgress
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <SalesForecast
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <SmartAlerts
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <div class="pt-business-hub">

                        <!-- CLIENTS -->

                        <div class="pt-group-section">

                            <div class="pt-group-title">

                                Analyse Clients

                            </div>

                            <div class="pt-group-box">

                                <div class="pt-group-card">

                                    <TopCustomers
                                        filters="state.filters"
                                        refreshKey="state.refreshKey"/>

                                </div>

                                <div class="pt-group-chart">

                                    <TopCustomersChart
                                        filters="state.filters"
                                        refreshKey="state.refreshKey"/>

                                </div>

                            </div>

                        </div>

                        <!-- PRODUITS -->

                        <div class="pt-group-section">

                            <div class="pt-group-title">

                                Analyse Produits

                            </div>

                            <div class="pt-group-box reverse">

                                <div class="pt-group-chart">

                                    <TopProductsChart
                                        filters="state.filters"
                                        refreshKey="state.refreshKey"/>

                                </div>

                                <div class="pt-group-card">

                                    <TopProducts
                                        filters="state.filters"
                                        refreshKey="state.refreshKey"/>

                                </div>

                            </div>

                        </div>

                        <!-- COMMERCIAUX -->

                        <div class="pt-group-section">

                            <div class="pt-group-title">

                                Analyse Commerciale

                            </div>

                            <div class="pt-group-box">

                                <div class="pt-group-card">

                                    <TopSalespersons
                                        filters="state.filters"
                                        refreshKey="state.refreshKey"/>

                                </div>

                                <div class="pt-group-chart">

                                    <TopSalespersonsChart
                                        filters="state.filters"
                                        refreshKey="state.refreshKey"/>

                                </div>

                            </div>

                        </div>

                    </div>

                    <RiskCenter
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <AlertsPanel
                        filters="state.filters"
                        refreshKey="state.refreshKey"/>

                    <div class="pt-row">

                        <RecentActivities/>

                        <FavoriteReports/>

                    </div>

                    <QuickActions/>

                </div>

            </div>

        </div>

    </t>

</templates>
