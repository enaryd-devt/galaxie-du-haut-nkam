<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

<t t-name="primetech_reporting_center.SalesOverviewDashboard">

<div class="pt-dashboard container-fluid">

    <!-- LOADING -->

    <t t-if="!state.loaded">

        <div class="text-center p-5">

            <i
                class="
                    fa fa-spinner
                    fa-spin
                    fa-3x
                "
            />

            <h4 class="mt-3">

                Chargement du Dashboard...

            </h4>

        </div>

    </t>

    <!-- DASHBOARD -->

    <t t-if="state.loaded">

        <!-- ===================================== -->
        <!-- HEADER PREMIUM -->
        <!-- ===================================== -->

        <div class="dashboard-header">

            <div
                class="
                    d-flex
                    justify-content-between
                    align-items-center
                "
            >

                <div>

                    <div class="dashboard-subtitle">

                        SALES ET CUSTOMER MANAGEMENT

                    </div>

                    <h1>

                        Vue d'Ensemble Commerciale

                    </h1>

                    <div class="text-muted">

                        Pilotage des ventes,
                        facturation et performances

                    </div>

                </div>

                <div class="dashboard-badge">

                    <i
                        class="
                            fa fa-briefcase
                            me-2
                        "
                    />

                    Executive Sales Dashboard

                </div>

            </div>

        </div>

        <!-- ===================================== -->
        <!-- KPI LIGNE 1 -->
        <!-- ===================================== -->

        <div class="row g-4">

            <!-- CA HT -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-green
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-money"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                CA HT

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.turnover_ht
                                        ?.toLocaleString()
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- CA TTC -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-blue
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-credit-card"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                CA TTC

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.turnover_ttc
                                        ?.toLocaleString()
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- CA MOIS -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-orange
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-calendar"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                CA du Mois

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.turnover_month
                                        ?.toLocaleString()
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- CROISSANCE -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-cyan
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-upload"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                Croissance

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.growth_rate
                                    "
                                />%

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ===================================== -->
        <!-- KPI LIGNE 2 -->
        <!-- ===================================== -->

        <div class="row g-4 mt-1">

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-indigo
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-users"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                Clients

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.customer_count
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>
                        <!-- FACTURES -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-purple
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-file-text-o"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                Factures

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.invoice_count
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- COMMANDES -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-blue
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-shopping-cart"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                Commandes

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.order_count
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- PANIER -->

            <div class="col-xl-3 col-lg-6">

                <div
                    class="
                        dashboard-card
                        kpi-card
                        kpi-orange
                    "
                >

                    <div class="card-body">

                        <div class="kpi-icon">

                            <i class="fa fa-calculator"/>

                        </div>

                        <div class="kpi-content">

                            <div class="kpi-title">

                                Panier Moyen

                            </div>

                            <div class="kpi-value">

                                <t
                                    t-esc="
                                        state.data.average_ticket
                                        ?.toLocaleString()
                                    "
                                />

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ===================================== -->
        <!-- KPI FINANCIERS -->
        <!-- ===================================== -->

        <div class="row mt-4">

            <div class="col-lg-6">

                <div
                    class="
                        stock-alert
                        stock-alert-danger
                    "
                >

                    <div
                        class="
                            stock-alert-icon
                        "
                    >

                        <i class="fa fa-file-text-o"/>

                    </div>

                    <div
                        class="
                            stock-alert-content
                        "
                    >

                        <div
                            class="
                                stock-alert-title
                            "
                        >

                            Factures Impayées

                        </div>

                        <div
                            class="
                                stock-alert-value
                            "
                        >

                            <t
                                t-esc="
                                    state.data.unpaid_amount
                                    ?.toLocaleString()
                                "
                            />

                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-6">

                <div
                    class="
                        stock-alert
                        stock-alert-warning
                    "
                >

                    <div
                        class="
                            stock-alert-icon
                        "
                    >

                        <i
                            class="
                                fa fa-shopping-cart
                            "
                        />

                    </div>

                    <div
                        class="
                            stock-alert-content
                        "
                    >

                        <div
                            class="
                                stock-alert-title
                            "
                        >

                            Commandes à Facturer

                        </div>

                        <div
                            class="
                                stock-alert-value
                            "
                        >

                            <t
                                t-esc="
                                    state.data.to_invoice_amount
                                    ?.toLocaleString()
                                "
                            />

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ===================================== -->
        <!-- EVOLUTION CA -->
        <!-- ===================================== -->

        <div class="row mt-4">

            <div class="col-12">

                <div class="dashboard-card">

                    <div class="card-header">

                        <div
                            class="
                                d-flex
                                justify-content-between
                                align-items-center
                            "
                        >

                            <h5>

                                <i
                                    class="
                                        fa fa-chart-area
                                        me-2
                                    "
                                />

                                Evolution Mensuelle du CA

                            </h5>

                            <span
                                class="
                                    dashboard-badge
                                "
                            >

                                12 DERNIERS MOIS

                            </span>

                        </div>

                    </div>

                    <div class="card-body">

                        <canvas
                            id="salesEvolutionChart"
                            height="120"
                        />

                    </div>

                </div>

            </div>

        </div>

        <!-- ===================================== -->
        <!-- TOP COMMERCIAUX -->
        <!-- ===================================== -->

        <div class="row mt-4">

            <div class="col-12">

                <div class="dashboard-card">

                    <div class="card-header">

                        <div
                            class="
                                d-flex
                                justify-content-between
                                align-items-center
                            "
                        >

                            <h5>

                                <i
                                    class="
                                        fa fa-trophy
                                        me-2
                                    "
                                />

                                Top 10 Commerciaux

                            </h5>

                            <span
                                class="
                                    dashboard-badge
                                "
                            >

                                TOP 10

                            </span>

                        </div>

                    </div>

                    <div class="table-responsive">

                        <table
                            class="
                                table
                                table-hover
                                mb-0
                            "
                        >

                            <thead>

                                <tr>

                                    <th>
                                        Commercial
                                    </th>

                                    <th
                                        class="
                                            text-end
                                        "
                                    >
                                        Chiffre d'Affaires
                                    </th>

                                </tr>

                            </thead>

                            <tbody>

                                <tr
                                    t-foreach="
                                        state.data.top_salespersons || []
                                    "
                                    t-as="sp"
                                    t-key="sp.name"
                                >

                                    <td>

                                        <div
                                            class="
                                                d-flex
                                                align-items-center
                                                gap-2
                                            "
                                        >

                                            <i
                                                class="
                                                    fa fa-user-tie
                                                    text-primary
                                                "
                                            />

                                            <span>

                                                <t
                                                    t-esc="
                                                        sp.name
                                                    "
                                                />

                                            </span>

                                        </div>

                                    </td>

                                    <td
                                        class="
                                            text-end
                                            fw-bold
                                        "
                                    >

                                        <t
                                            t-esc="
                                                sp.amount
                                                .toLocaleString()
                                            "
                                        />

                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

        <!-- ===================================== -->
        <!-- CLIENTS + PRODUITS -->
        <!-- ===================================== -->

        <div class="row mt-4">

            <div class="col-xl-6">

                <div class="dashboard-card">

                    <div class="card-header">

                        <h5>

                            <i
                                class="
                                    fa fa-building
                                    me-2
                                "
                            />

                            Top Clients

                        </h5>

                    </div>

                    <div class="table-responsive">

                        <table
                            class="
                                table
                                table-hover
                                mb-0
                            "
                        >

                            <tbody>

                                <tr
                                    t-foreach="
                                        state.data.top_customers || []
                                    "
                                    t-as="customer"
                                    t-key="customer.name"
                                >

                                    <td>

                                        <i
                                            class="
                                                fa fa-building
                                                text-success
                                                me-2
                                            "
                                        />

                                        <t
                                            t-esc="
                                                customer.name
                                            "
                                        />

                                    </td>

                                    <td
                                        class="
                                            text-end
                                            fw-bold
                                        "
                                    >

                                        <t
                                            t-esc="
                                                customer.amount
                                                .toLocaleString()
                                            "
                                        />

                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

            <div class="col-xl-6">

                <div class="dashboard-card">

                    <div class="card-header">

                        <h5>

                            <i
                                class="
                                    fa fa-box
                                    me-2
                                "
                            />

                            Top Produits

                        </h5>

                    </div>

                    <div class="table-responsive">

                        <table
                            class="
                                table
                                table-hover
                                mb-0
                            "
                        >

                            <tbody>

                                <tr
                                    t-foreach="
                                        state.data.top_products || []
                                    "
                                    t-as="product"
                                    t-key="product.name"
                                >

                                    <td>

                                        <i
                                            class="
                                                fa fa-box
                                                text-warning
                                                me-2
                                            "
                                        />

                                        <t
                                            t-esc="
                                                product.name
                                            "
                                        />

                                    </td>

                                    <td
                                        class="
                                            text-end
                                            fw-bold
                                        "
                                    >

                                        <t
                                            t-esc="
                                                product.amount
                                                .toLocaleString()
                                            "
                                        />

                                    </td>

                                </tr>

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </t>

</div>

</t>

</templates>