<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- SEARCH -->

    <record id="view_committee_search" model="ir.ui.view">
        <field name="name">association.committee.search</field>
        <field name="model">association.committee</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="member_id"/>
                <field name="function_id"/>

                <filter string="Draft"
                    domain="[('state','=','draft')]"/>

                <filter string="Running"
                    domain="[('state','=','running')]"/>

                <filter string="Expired"
                    domain="[('state','=','expired')]"/>
            </search>
        </field>
    </record>

    <!-- TREE -->

    <record id="view_committee_tree" model="ir.ui.view">
        <field name="name">association.committee.tree</field>
        <field name="model">association.committee</field>
        <field name="arch" type="xml">
            <list>

                <field name="name"/>
                <field name="member_id"/>
                <field name="function_id"/>
                <field name="start_date"/>
                <field name="end_date"/>

                <field name="state" widget="badge"/>

            </list>
        </field>
    </record>

    <!-- FORM -->

    <record id="view_committee_form" model="ir.ui.view">
        <field name="name">association.committee.form</field>
        <field name="model">association.committee</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <field
                        name="state"
                        widget="statusbar"/>

                </header>

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>

                            <field name="member_id"/>

                            <field name="function_id"/>

                        </group>

                        <group>

                            <field name="start_date"/>

                            <field name="end_date"/>

                            <field name="is_signatory"/>

                            <field name="is_financial"/>

                        </group>

                    </group>

                    <notebook>

                        <page string="Notes">

                            <field name="note"/>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>

    </record>

</odoo>