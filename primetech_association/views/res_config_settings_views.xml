<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_association"
            model="ir.ui.view">

        <field name="name">res.config.settings.view.form.association</field>

        <field name="model">res.config.settings</field>

        <field name="inherit_id"
               ref="base.res_config_settings_view_form"/>

        <field name="arch"
               type="xml">

            <xpath expr="//form"
                   position="inside">

                <app string="Association"
                     name="association_settings">

                    <block title="General Settings">

                        <setting string="Association Name">

                            <field name="association_name"/>

                        </setting>

                        <setting string="Membership Prefix">

                            <field name="membership_prefix"/>

                        </setting>

                        <setting string="Membership Card Validity">

                            <field name="membership_card_validity"/>

                        </setting>

                        <setting string="Default Subscription Amount">

                            <field name="default_subscription_amount"/>

                        </setting>

                        <setting string="Allow Partial Payments">

                            <field name="allow_partial_payment"/>

                        </setting>

                        <setting string="Require Member Photo">

                            <field name="require_member_photo"/>

                        </setting>

                        <setting string="Automatic Member Number">

                            <field name="automatic_member_number"/>

                        </setting>

                    </block>

                </app>

            </xpath>

        </field>

    </record>

</odoo>