<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_expense_search" model="ir.ui.view">
        <field name="name">association.expense.search</field>
        <field name="model">association.expense</field>
        <field name="arch" type="xml">

            <search>

                <field name="name"/>

                <field name="beneficiary"/>

            </search>

        </field>
    </record>

    <record id="view_expense_tree" model="ir.ui.view">
        <field name="name">association.expense.tree</field>
        <field name="model">association.expense</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>

                <field name="expense_date"/>

                <field name="beneficiary"/>

                <field name="amount"/>

                <field name="state"
                       widget="badge"/>

            </list>

        </field>
    </record>

    <record id="view_expense_form" model="ir.ui.view">
        <field name="name">association.expense.form</field>
        <field name="model">association.expense</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <field name="state"
                           widget="statusbar"/>

                </header>

                <sheet>

                    <group>

                        <field name="name"/>

                        <field name="expense_date"/>

                        <field name="beneficiary"/>

                        <field name="payment_method"/>

                        <field name="amount"/>

                    </group>

                    <field name="note"/>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>