<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_member_category_tree" model="ir.ui.view">
        <field name="name">association.member.category.tree</field>
        <field name="model">association.member.category</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>

                <field name="code"/>

                <field name="member_count"/>

                <field name="active"/>

            </list>

        </field>
    </record>

    <record id="view_member_category_form" model="ir.ui.view">
        <field name="name">association.member.category.form</field>
        <field name="model">association.member.category</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="name"/>

                        <field name="code"/>

                        <field name="description"/>

                        <field name="is_default"/>

                        <field name="active"/>

                    </group>

                    <field name="note"/>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

    <!-- ==================== MEMBER FUNCTIONS ==================== -->

    <record id="view_member_function_tree" model="ir.ui.view">
        <field name="name">association.member.function.tree</field>
        <field name="model">association.member.function</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>

                <field name="code"/>

                <field name="member_count"/>

                <field name="executive_member"/>

            </list>

        </field>
    </record>

    <record id="view_member_function_form" model="ir.ui.view">
        <field name="name">association.member.function.form</field>
        <field name="model">association.member.function</field>
        <field name="arch" type="xml">

            <form>

                <sheet>

                    <group>

                        <field name="name"/>

                        <field name="code"/>

                        <field name="description"/>

                        <field name="executive_member"/>

                        <field name="election_required"/>

                        <field name="max_holders"/>

                    </group>

                    <field name="note"/>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

</odoo>