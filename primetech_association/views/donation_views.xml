<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_donation_search" model="ir.ui.view">
        <field name="name">association.donation.search</field>
        <field name="model">association.donation</field>
        <field name="arch" type="xml">

            <search>

                <field name="name"/>

                <field name="donor"/>

                <field name="member_id"/>

            </search>

        </field>
    </record>

    <record id="view_donation_tree" model="ir.ui.view">
        <field name="name">association.donation.tree</field>
        <field name="model">association.donation</field>
        <field name="arch" type="xml">

            <list>

                <field name="name"/>

                <field name="donor"/>

                <field name="donation_date"/>

                <field name="amount"/>

                <field name="state"
                       widget="badge"/>

            </list>

        </field>
    </record>

    <record id="view_donation_form" model="ir.ui.view">
        <field name="name">association.donation.form</field>
        <field name="model">association.donation</field>
        <field name="arch" type="xml">

            <form>

                <header>

                    <field name="state"
                           widget="statusbar"/>

                </header>

                <sheet>

                    <group>

                        <group>

                            <field name="name"/>

                            <field name="donor"/>

                            <field name="member_id"/>

                        </group>

                        <group>

                            <field name="donation_date"/>

                            <field name="donation_type"/>

                            <field name="amount"/>

                        </group>

                    </group>

                    <field name="note"/>

                </sheet>

                <chatter/>

            </form>

        </field>

    </record>

</odoo>