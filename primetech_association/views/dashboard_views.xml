<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- DASHBOARD FORM                                            -->
    <!-- ========================================================= -->

    <record id="view_association_dashboard_form" model="ir.ui.view">
        <field name="name">association.dashboard.form</field>
        <field name="model">association.dashboard</field>
        <field name="arch" type="xml">

            <form string="Association Dashboard" create="0" edit="0" delete="0">

                <sheet>

                    <div class="oe_title">
                        <h1>Association Dashboard</h1>
                        <h3>PrimeTech Association Management</h3>
                    </div>

                    <group string="Key Indicators" col="3">

                        <field name="member_count" readonly="1"/>

                        <field name="active_member_count" readonly="1"/>

                        <field name="subscription_count" readonly="1"/>

                        <field name="payment_count" readonly="1"/>

                        <field name="meeting_count" readonly="1"/>

                        <field name="donation_count" readonly="1"/>

                    </group>

                    <group string="Financial Summary" col="3">

                        <field name="income" readonly="1"/>

                        <field name="expense" readonly="1"/>

                        <field name="balance" readonly="1"/>

                    </group>

                    <separator string="Upcoming Features"/>

                    <div class="alert alert-info" role="alert">
                        <strong>Version 1</strong><br/>
                        The advanced dashboard with charts, KPIs, quick actions and statistics
                        will be available in the next version.
                    </div>
                </sheet>

            </form>

        </field>
    </record>

</odoo>