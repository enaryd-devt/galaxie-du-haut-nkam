<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- MEMBER -->
    <!-- ========================================================= -->

    <record id="seq_association_member" model="ir.sequence">
        <field name="name">Association Member</field>
        <field name="code">association.member</field>
        <field name="prefix">MEM/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
    </record>

    <!-- ========================================================= -->
    <!-- SUBSCRIPTION -->
    <!-- ========================================================= -->

    <record id="seq_association_subscription" model="ir.sequence">
        <field name="name">Association Subscription</field>
        <field name="code">association.subscription</field>
        <field name="prefix">SUB/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- ========================================================= -->
    <!-- PAYMENT -->
    <!-- ========================================================= -->

    <record id="seq_association_payment" model="ir.sequence">
        <field name="name">Association Payment</field>
        <field name="code">association.payment</field>
        <field name="prefix">PAY/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- ========================================================= -->
    <!-- MEETING -->
    <!-- ========================================================= -->

    <record id="seq_association_meeting" model="ir.sequence">
        <field name="name">Association Meeting</field>
        <field name="code">association.meeting</field>
        <field name="prefix">MTG/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- ========================================================= -->
    <!-- DONATION -->
    <!-- ========================================================= -->

    <record id="seq_association_donation" model="ir.sequence">
        <field name="name">Association Donation</field>
        <field name="code">association.donation</field>
        <field name="prefix">DON/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- ========================================================= -->
    <!-- EXPENSE -->
    <!-- ========================================================= -->

    <record id="seq_association_expense" model="ir.sequence">
        <field name="name">Association Expense</field>
        <field name="code">association.expense</field>
        <field name="prefix">EXP/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- ========================================================= -->
    <!-- INCOME -->
    <!-- ========================================================= -->

    <record id="seq_association_income" model="ir.sequence">
        <field name="name">Association Income</field>
        <field name="code">association.income</field>
        <field name="prefix">INC/%(year)s/</field>
        <field name="padding">5</field>
    </record>

    <!-- ========================================================= -->
    <!-- MEMBER CARD -->
    <!-- ========================================================= -->

    <record id="seq_association_card" model="ir.sequence">
        <field name="name">Association Member Card</field>
        <field name="code">association.card</field>
        <field name="prefix">CARD/%(year)s/</field>
        <field name="padding">5</field>
    </record>

</odoo>