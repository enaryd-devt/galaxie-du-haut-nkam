<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="product_product_stock_dashboard"
            model="ir.ui.view">

        <field name="name">product.product.stock.dashboard</field>
        <field name="model">product.product</field>

        <field name="inherit_id"
               ref="product.product_normal_form_view"/>

        <field name="arch" type="xml">

            <field name="product_tooltip"
                   position="after">

                <div class="o_stock_dashboard"
                     invisible="not has_stock_alerts">

                    <!-- Résumé -->

                    <div style="
                        display:flex;
                        gap:24px;
                        align-items:flex-start;
                    ">

                        <div style="flex:0 0 40%;max-width:40%;">

                            <field name="packaging_summary"
                                   widget="html"
                                   nolabel="1"/>

                        </div>

                        <div style="flex:0 0 60%;max-width:60%;">

                            <field name="warehouse_summary"
                                   widget="html"
                                   nolabel="1"/>

                        </div>

                    </div>

                    <!-- Tableau -->

                    <field name="stock_alert_ids"
                           nolabel="1">

                        <list
                            create="0"
                            delete="0"
                            editable="bottom">

                            <field name="location_id"/>
                            <field name="lot_id"/>
                            <field name="expiration_date"/>
                            <field name="available_quantity"/>
                            <field name="minimum_qty"/>
                            <field name="status_html"
                                   widget="html"/>

                        </list>

                    </field>

                </div>

            </field>

        </field>

    </record>

</odoo>